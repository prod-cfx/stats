# e2e 测试环境
APP_ENV=e2e

POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=__SET_IN_env.local__
POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

REDIS_HOST=127.0.0.1
REDIS_PORT=6380
REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

# JWT
JWT_SECRET=__SET_IN_env.local__
JWT_EXPIRES_IN=30d

# 邮件
RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# 通用
APP_SECRET=__SET_IN_env.local__
LOG_LEVEL=error

QUANTIFY_DATABASE_URL=__SET_IN_env.local__
QUANTIFY_REDIS_URL=__SET_IN_env.local__
QUANTIFY_APP_SECRET=__SET_IN_env.local__
QUANTIFY_JWT_SECRET=__SET_IN_env.local__
QUANTIFY_EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__
QUANTIFY_PORT=__SET_IN_env.local__
QUANTIFY_BASE_URL=__SET_IN_env.local__

NEXT_PUBLIC_APP_ENV=${APP_ENV}
NEXT_PUBLIC_API_SERVER_URL=__SET_IN_env.local__
NEXT_PUBLIC_API_BASE_URL=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_API_KEY=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_BASE_URL=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_MODEL=__SET_IN_env.local__
TRANSLATE_LLM_API_KEY=__SET_IN_env.local__
TRANSLATE_LLM_BASE_URL=__SET_IN_env.local__
TRANSLATE_LLM_MODEL=__SET_IN_env.local__

EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__

# Quantify fixed Binance testnet bootstrap
QUANTIFY_FIXED_BINANCE_TESTNET_ENABLED=false
QUANTIFY_FIXED_BINANCE_TESTNET_USER_EMAIL=binance-testnet-fixed@local.dev
QUANTIFY_FIXED_BINANCE_TESTNET_USER_NICKNAME=Binance Testnet Fixed User
QUANTIFY_FIXED_BINANCE_TESTNET_OPERATOR_ID=system-fixed-binance-seed
QUANTIFY_FIXED_BINANCE_TESTNET_BASE_ASSET=BTC
QUANTIFY_FIXED_BINANCE_PERP_TESTNET_BASE_ASSET=XRP
QUANTIFY_FIXED_BINANCE_TESTNET_QUOTE_ASSET=USDT
QUANTIFY_FIXED_BINANCE_TESTNET_INITIAL_BALANCE=10
QUANTIFY_FIXED_BINANCE_SPOT_TESTNET_API_KEY=__SET_IN_env.local__
QUANTIFY_FIXED_BINANCE_SPOT_TESTNET_API_SECRET=__SET_IN_env.local__
QUANTIFY_FIXED_BINANCE_PERP_TESTNET_API_KEY=__SET_IN_env.local__
QUANTIFY_FIXED_BINANCE_PERP_TESTNET_API_SECRET=__SET_IN_env.local__
QUANTIFY_FIXED_BINANCE_TESTNET_API_KEY=__SET_IN_env.local__
QUANTIFY_FIXED_BINANCE_TESTNET_API_SECRET=__SET_IN_env.local__

# Quantify fixed Hyperliquid testnet bootstrap
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_ENABLED=false
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_USER_EMAIL=hyperliquid-testnet-fixed@local.dev
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_USER_NICKNAME=Hyperliquid Testnet Fixed User
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_OPERATOR_ID=system-fixed-hyperliquid-seed
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_BASE_ASSET=BTC
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_QUOTE_ASSET=USDC
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_INITIAL_BALANCE=1000
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_MAIN_WALLET_ADDRESS=__SET_IN_env.local__
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_AGENT_PRIVATE_KEY=__SET_IN_env.local__
QUANTIFY_FIXED_HYPERLIQUID_TESTNET_IS_TESTNET=true
# BBX API (加密股票报价)
BBX_ACCESS_KEY_ID=__SET_IN_env.local__
BBX_ACCESS_SECRET=__SET_IN_env.local__

# Vercel 部署配置
VERCEL_TOKEN=__SET_IN_env.local__
VERCEL_GIT_COMMIT_AUTHOR_EMAIL=__SET_IN_env.local__
# Trades WebSocket ingestion (markets/trades)
# Enable trades WS ingestion (set true to enable)
TRADES_WS_ENABLED=__SET_IN_env.local__

# Sync interval (ms), minimum 1000
TRADES_WS_SYNC_INTERVAL_MS=__SET_IN_env.local__

# OKX trades WS base URL (no path)
# e.g. wss://ws.okx.com:8443
TRADES_OKX_WS_BASE_URL=__SET_IN_env.local__

# Max streams per WS connection (sharding)
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=__SET_IN_env.local__

# Trades retention days (CleanupOldTradesJob)
TRADES_RETENTION_DAYS=__SET_IN_env.local__

# Hyperliquid WebSocket
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Whale Notification
WHALE_NOTIFICATION_ENABLED=true
WHALE_NOTIFICATION_ALLOWED_USER_IDS=
WHALE_NOTIFICATION_COOLDOWN_SECONDS=60
WHALE_NOTIFICATION_RETRY_MAX_ATTEMPTS=3
WHALE_NOTIFICATION_RETRY_BACKOFF_MS=0

# Quantify fixed OKX simulated trading bootstrap
QUANTIFY_FIXED_OKX_ENABLED=false
QUANTIFY_FIXED_OKX_USER_EMAIL=okx-sim-fixed@local.dev
QUANTIFY_FIXED_OKX_USER_NICKNAME=OKX Sim Fixed User
QUANTIFY_FIXED_OKX_OPERATOR_ID=system-fixed-okx-seed
QUANTIFY_FIXED_OKX_IS_TESTNET=true
QUANTIFY_FIXED_OKX_API_KEY=__SET_IN_env.local__
QUANTIFY_FIXED_OKX_API_SECRET=__SET_IN_env.local__
QUANTIFY_FIXED_OKX_API_PASSPHRASE=__SET_IN_env.local__
QUANTIFY_FIXED_OKX_SPOT_BASE_ASSET=BTC
QUANTIFY_FIXED_OKX_PERP_BASE_ASSET=BTC
QUANTIFY_FIXED_OKX_QUOTE_ASSET=USDT
QUANTIFY_FIXED_OKX_INITIAL_BALANCE=1000
