# 统一敏感环境变量模板
# 所有字段都必须保持占位符 __SET_IN_env.local__，真实值写入 .env.<env>.local。
# 非敏感配置项请在 .env.<env> 文件中定义。

# 数据库
POSTGRES_HOST=__SET_IN_env.local__
POSTGRES_PORT=__SET_IN_env.local__
POSTGRES_USER=__SET_IN_env.local__
POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

# Redis
REDIS_HOST=__SET_IN_env.local__
REDIS_PORT=__SET_IN_env.local__
REDIS_DB=__SET_IN_env.local__
REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

# 应用密钥
APP_SECRET=__SET_IN_env.local__
JWT_SECRET=__SET_IN_env.local__

# Quantify service secrets
QUANTIFY_DATABASE_URL=__SET_IN_env.local__
QUANTIFY_REDIS_URL=__SET_IN_env.local__
QUANTIFY_APP_SECRET=__SET_IN_env.local__
QUANTIFY_JWT_SECRET=__SET_IN_env.local__
QUANTIFY_PORT=__SET_IN_env.local__
QUANTIFY_BASE_URL=__SET_IN_env.local__

# GitHub 账号配置（用于 git 提交和 gh CLI 操作）
GH_ACCOUNT=__SET_IN_env.local__

# 邮件服务
RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__

# 交易所账户加密
EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__

# Coinglass
COINGLASS_API_KEY=__SET_IN_env.local__

# Data sync
# BACKFILL_RECHECK_WINDOW_DAYS: 回填完成后再检查 earliestRecord 的间隔天数（默认 90）
BACKFILL_RECHECK_WINDOW_DAYS=__SET_IN_env.local__

# Polymarket API Keys
POLYMARKET_GAMMA_API_KEY=__SET_IN_env.local__
POLYMARKET_CLOB_API_KEY=__SET_IN_env.local__
TRANSLATE_LLM_API_KEY=__SET_IN_env.local__
TRANSLATE_LLM_BASE_URL=__SET_IN_env.local__
TRANSLATE_LLM_MODEL=__SET_IN_env.local__
POLYMARKET_TRANSLATE_ENABLED=true

# BBX API (加密股票报价)
BBX_ACCESS_KEY_ID=__SET_IN_env.local__
BBX_ACCESS_SECRET=__SET_IN_env.local__

# Hyperliquid API（公共端点，无需 API Key）
# 默认值：https://api.hyperliquid.xyz
# 测试网：https://api.hyperliquid-testnet.xyz
HYPERLIQUID_API_URL=__SET_IN_env.local__
NEXT_PUBLIC_HYPERLIQUID_API_URL=__SET_IN_env.local__

# Hyperliquid WebSocket 配置
# HYPERLIQUID_TRADES_WS_ENABLED: 是否启用 Hyperliquid 鲸鱼交易 WebSocket 订阅（默认 false）
# HYPERLIQUID_WS_URL: Hyperliquid WebSocket 地址（默认 wss://api.hyperliquid.xyz/ws）
# HYPERLIQUID_WHALE_REFRESH_INTERVAL_MS: 鲸鱼列表刷新间隔毫秒（默认 300000，最小 30000）
HYPERLIQUID_TRADES_WS_ENABLED=false
HYPERLIQUID_WS_URL=__SET_IN_env.local__
HYPERLIQUID_WHALE_REFRESH_INTERVAL_MS=__SET_IN_env.local__

# Whale Notification
# WHALE_NOTIFICATION_ENABLED: 是否启用巨鲸通知编排（默认 true）
# WHALE_NOTIFICATION_ALLOWED_USER_IDS: 灰度白名单（逗号分隔用户 ID），留空表示全量
# WHALE_NOTIFICATION_COOLDOWN_SECONDS: 去重冷却秒数（默认 60）
# WHALE_NOTIFICATION_RETRY_MAX_ATTEMPTS: 渠道发送最大重试次数（默认 3）
# WHALE_NOTIFICATION_RETRY_BACKOFF_MS: 渠道重试间隔毫秒（默认 500）
WHALE_NOTIFICATION_ENABLED=__SET_IN_env.local__
WHALE_NOTIFICATION_ALLOWED_USER_IDS=__SET_IN_env.local__
WHALE_NOTIFICATION_COOLDOWN_SECONDS=__SET_IN_env.local__
WHALE_NOTIFICATION_RETRY_MAX_ATTEMPTS=__SET_IN_env.local__
WHALE_NOTIFICATION_RETRY_BACKOFF_MS=__SET_IN_env.local__

# Vercel 部署配置
VERCEL_TOKEN=__SET_IN_env.local__
VERCEL_ORG_ID=__SET_IN_env.local__
VERCEL_PROJECT_ID_FRONT=__SET_IN_env.local__
VERCEL_PROJECT_ID_ADMIN=__SET_IN_env.local__

# Orderbook WebSocket 配置
# ORDERBOOK_WS_ENABLED: 是否启用 WebSocket 订单薄同步（默认 true）
# ORDERBOOK_BITMAX_ENABLED: 是否启用 Bitmax/AscendEX 订单薄同步（默认 false）
# ORDERBOOK_WS_BITMAX_GAP_THRESHOLD: Bitmax seqnum 断档检测阈值（默认 200）
# ORDERBOOK_WS_GAP_WARN_INTERVAL_MS: seqnum 断档告警降噪间隔毫秒（默认 10000）
# ORDERBOOK_WS_PUBLISH_INTERVAL_MS: 订单薄发布到 Redis 的间隔毫秒（默认 250）
# ORDERBOOK_WS_HEARTBEAT_INTERVAL_MS: WebSocket 心跳间隔毫秒（默认 15000）
# ORDERBOOK_WS_HEARTBEAT_TIMEOUT_MS: WebSocket 心跳超时毫秒（默认 45000）
