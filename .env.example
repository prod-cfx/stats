# 统一敏感环境变量模板（与 /Users/a1/work/ai-monorepo 一致）
# 所有字段都必须保持占位符 __SET_IN_env.local__，真实值写入 .env.<env>.local。

# 数据库
POSTGRES_HOST=__SET_IN_env.local__
POSTGRES_PORT=__SET_IN_env.local__
POSTGRES_USER=__SET_IN_env.local__
POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

# Redis
REDIS_HOST=__SET_IN_env.local__
REDIS_PORT=__SET_IN_env.local__
REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

# 应用密钥
APP_SECRET=__SET_IN_env.local__
JWT_SECRET=__SET_IN_env.local__

# GitHub 账号配置（用于 git 提交和 gh CLI 操作）
GH_ACCOUNT=__SET_IN_env.local__

# 邮件服务
RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__

# Coinglass（DataSync: CoinglassHeatmapJob）
COINGLASS_API_KEY=__SET_IN_env.local__
# 可选：不填则使用 Job 内置默认地址
COINGLASS_HEATMAP_ENDPOINT=__SET_IN_env.local__

# （当前项目暂无其他必填敏感项）
EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__

REDIS_DB=__SET_IN_env.local__
# Polymarket（Gamma / CLOB）
POLYMARKET_GAMMA_API_KEY=__SET_IN_env.local__
POLYMARKET_CLOB_API_KEY=__SET_IN_env.local__
POLYMARKET_CLOB_BASE_URL=__SET_IN_env.local__
# 可选：不填则使用 Job 默认地址
POLYMARKET_GAMMA_BASE_URL=__SET_IN_env.local__
POLYMARKET_CLOB_WS_URL=__SET_IN_env.local__
POLYMARKET_CATEGORY=__SET_IN_env.local__
POLYMARKET_TAGS=__SET_IN_env.local__
# 可选：API 超时与限制配置（默认 10s / limit 200）
POLYMARKET_GAMMA_TIMEOUT_MS=__SET_IN_env.local__
POLYMARKET_GAMMA_LIMIT=__SET_IN_env.local__
POLYMARKET_CLOB_TIMEOUT_MS=__SET_IN_env.local__

# Trades WebSocket ingestion (markets/trades)
# Enable trades WS ingestion (set true to enable)
TRADES_WS_ENABLED=false

# Sync interval (ms), minimum 1000
TRADES_WS_SYNC_INTERVAL_MS=10000

# OKX trades WS base URL (no path)
# e.g. wss://ws.okx.com:8443
TRADES_OKX_WS_BASE_URL=wss://ws.okx.com:8443/ws/v5/public

# Max streams per WS connection (sharding)
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=50

# Trades retention days (CleanupOldTradesJob)
TRADES_RETENTION_DAYS=7
