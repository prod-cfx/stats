# Cursor ignore file - prevents indexing of these paths
# This significantly improves performance

# Node modules
node_modules/
**/node_modules/

# Build outputs
dist/
.next/
out/
build/

# Logs
logs/
*.log

# Cache
.nx/
.cache/

# Worktrees (CRITICAL - prevents Cursor from indexing all worktrees)
# Multiple patterns to ensure worktrees are excluded
../.cursor/worktrees/
~/.cursor/worktrees/
**/.cursor/worktrees/
.cursor/worktrees/

# Worktree node_modules (worktrees may have their own node_modules)
**/.cursor/worktrees/**/node_modules/
~/.cursor/worktrees/**/node_modules/

# IDE
.idea/
.vscode/

# OS
.DS_Store

# Generated files (large, auto-generated, don't need indexing)
packages/api-contracts/src/generated/
packages/api-contracts/openapi/*.json
**/*.generated.ts
**/*.generated.js

# Large JSON files (workspace data, lock files)
**/workspace-data/
**/parsed-lock-file.json
pnpm-lock.yaml

# Prisma generated and migrations
**/prisma/migrations/
**/*.prisma.ts

# Test coverage
coverage/
.nyc_output/

# Temporary files
*.tmp
*.temp
*.swp
*.swo
*~

# Large locale files (if not needed for context)
# Uncomment if locale files are too large:
# apps/*/public/locales/

