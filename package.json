{
  "name": "net-monorepo",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "nx run-many --target=dev --projects=backend,front,admin-front --parallel",
    "lint": "nx run-many --target=lint --all",
    "test": "nx run-many --target=test --all",
    "build": "nx run-many --target=build --all",
    "graph": "nx graph",
    "affected:graph": "nx affected:graph",
    "dx:status": "dx status",
    "dx:lint": "dx lint",
    "dx:build:contracts": "dx build contracts --dev",
    "prepare": "husky install"
  },
  "dependencies": {
    "@nestjs/event-emitter": "^3.0.1",
    "@prisma/client": "^7.0.1",
    "@types/cron": "^2.4.3",
    "async-mutex": "^0.5.0",
    "cron": "^4.3.4",
    "date-fns": "^3.6.0",
    "date-fns-tz": "^3.2.0",
    "i18next": "^24.2.3",
    "i18next-browser-languagedetector": "^8.2.0",
    "i18next-http-backend": "^3.0.2",
    "nestjs-cls": "^5.4.3",
    "openapi-zod-client": "1.18.1",
    "p-limit": "^4.0.0",
    "react-i18next": "^15.6.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^4.10.1",
    "@eslint-react/eslint-plugin": "^1.53.1",
    "@nx/eslint": "19.8.14",
    "@nx/jest": "19.8.14",
    "@nx/webpack": "19.8.14",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.7.5",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "autoprefixer": "^10.4.16",
    "concurrently": "^8.2.2",
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.32.0",
    "eslint-plugin-format": "^1.0.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.24",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.5",
    "lint-staged": "^15.5.2",
    "nx": "19.8.14",
    "pm2": "^6.0.13",
    "postcss": "^8.4.32",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "prisma": "^7.0.1",
    "tailwindcss": "^4.0.6",
    "tailwindcss-animate": "^1.0.7",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "yaml": "^2.6.0",
    "@ranger1/dx": "0.1.9"
  },
  "pnpm": {
    "ignoredBuiltDependencies": [
      "bufferutil",
      "utf-8-validate"
    ],
    "overrides": {
      "esbuild": "0.25.9",
      "@esbuild/*": "0.25.9",
      "@babel/helpers": "^7.28.4",
      "@babel/runtime": "^7.28.4",
      "@eslint/plugin-kit": "^0.3.5",
      "@typescript-eslint/eslint-plugin": "^8.35.1",
      "@typescript-eslint/parser": "^8.35.1",
      "@typescript-eslint/project-service": "^8.35.1",
      "@typescript-eslint/tsconfig-utils": "^8.35.1",
      "@typescript-eslint/type-utils": "^8.35.1",
      "@typescript-eslint/typescript-estree": "^8.35.1",
      "@typescript-eslint/utils": "^8.35.1",
      "brace-expansion@1": "1.1.12",
      "brace-expansion@2": "2.0.2",
      "form-data": "^4.0.4",
      "axios": "^1.12.0",
      "koa": "2.16.3",
      "react-router": "^7.8.2",
      "react-router-dom": "^7.8.2",
      "sweetalert2": "11.22.4",
      "tmp": "^0.2.5",
      "undici": "^7.16.0",
      "vite": "^7.1.11",
      "reflect-metadata": "^0.2.2",
      "@types/luxon": "^3.7.1",
      "cron": "^4.3.3",
      "typescript": "5.9.2"
    },
    "peerDependencyRules": {
      "ignoreMissing": [
        "eslint-plugin-vue",
        "@unocss/eslint-plugin"
      ],
      "allowedVersions": {
        "typescript": "5.9.2",
        "react": "18.2.0 || 18.3.1 || 19.0.0 || 19.1.0 || 19.2.0 || 19.2.4",
        "react-dom": "18.2.0 || 18.3.1 || 19.0.0 || 19.1.0 || 19.2.0 || 19.2.4",
        "@prisma/client": "7.0.1"
      }
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@openapitools/openapi-generator-cli",
      "@parcel/watcher",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "bcrypt",
      "bufferutil",
      "esbuild",
      "msgpackr-extract",
      "nx",
      "prisma",
      "sharp",
      "unrs-resolver",
      "utf-8-validate"
    ]
  },
  "lint-staged": {
    "apps/backend/**/*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write",
      "eslint --fix --config eslint.config.js"
    ],
    "apps/front/**/*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write",
      "eslint --fix --config eslint.config.js"
    ],
    "apps/admin-front/**/*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write",
      "eslint --fix --config eslint.config.js"
    ],
    "packages/**/*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write",
      "eslint --fix --config eslint.config.js"
    ],
    "*.{js,jsx,ts,tsx,json,md}": [
      "prettier --write"
    ]
  }
}
