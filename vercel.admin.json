{
  "$schema": "https://vercel.json.schema.vercel.sh",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && pnpm exec dx build shared && pnpm exec dx build admin --${APP_ENV}",
  "outputDirectory": "../../dist/admin-front",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
