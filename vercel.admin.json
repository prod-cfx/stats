{
  "$schema": "https://vercel.json.schema.vercel.sh",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && bash ./scripts/ci/vercel-build-admin.sh",
  "outputDirectory": "../../dist/admin-front",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
