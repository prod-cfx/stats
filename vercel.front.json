{
  "$schema": "https://vercel.json.schema.vercel.sh",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "buildCommand": "cd ../.. && npx -y @ranger1/dx@0.1.9 build shared && npx -y @ranger1/dx@0.1.9 build contracts --prod && npx -y @ranger1/dx@0.1.9 build front --${APP_ENV}",
  "outputDirectory": ".next",
  "redirects": [
    {
      "source": "/:path*/index.txt",
      "destination": "/:path*",
      "permanent": true
    },
    {
      "source": "/index.txt",
      "destination": "/",
      "permanent": true
    }
  ],
  "images": {
    "sizes": [640, 750, 828, 1080, 1200, 1920, 2048, 3840],
    "domains": []
  }
}
