{
  "name": "@ai/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./constants/*": {
      "types": "./dist/constants/*.d.ts",
      "default": "./dist/constants/*.js"
    },
    "./script-engine": {
      "types": "./dist/script-engine/index.d.ts",
      "default": "./dist/script-engine/index.js"
    },
    "./script-engine/*": {
      "types": "./dist/script-engine/*.d.ts",
      "default": "./dist/script-engine/*.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && pnpm exec tsc --project tsconfig.json",
    "dev": "pnpm exec tsc --project tsconfig.json --watch"
  }
}
