{
  "name": "@ai/shared",
  "version": "0.1.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "scripts": {
    "build": "rm -f tsconfig.tsbuildinfo && tsc --project tsconfig.json",
    "dev": "tsc --project tsconfig.json --watch"
  }
}
