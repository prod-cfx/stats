{
  "name": "api-contracts",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/api-contracts/src",
  "projectType": "library",
  "tags": ["scope:shared", "type:contracts"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/packages/api-contracts/dist"],
      "options": {
        "command": "pnpm --filter @ai/api-contracts run build"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd packages/api-contracts && npx eslint --max-warnings=9999 --no-warn-ignored --config ../../eslint.config.js src/index.ts"
      }
    }
  }
}
