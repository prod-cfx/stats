# Trades WebSocket ingestion (markets/trades)
# Enable trades WS ingestion (set true to enable)
TRADES_WS_ENABLED=__SET_IN_env.local__

# Sync interval (ms), minimum 1000
TRADES_WS_SYNC_INTERVAL_MS=__SET_IN_env.local__

# OKX trades WS base URL (no path)
# e.g. wss://ws.okx.com:8443
TRADES_OKX_WS_BASE_URL=__SET_IN_env.local__

# Max streams per WS connection (sharding)
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=__SET_IN_env.local__

# Trades retention days (CleanupOldTradesJob)
TRADES_RETENTION_DAYS=__SET_IN_env.local__

