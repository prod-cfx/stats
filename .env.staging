# 预发布环境
APP_ENV=staging

#POSTGRES_HOST=__SET_IN_env.local__
#POSTGRES_PORT=5432
#POSTGRES_USER=__SET_IN_env.local__
#POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

#REDIS_HOST=__SET_IN_env.local__
#REDIS_PORT=6379
#REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

JWT_SECRET=__SET_IN_env.local__
JWT_EXPIRES_IN=30d

APP_SECRET=__SET_IN_env.local__
LOG_LEVEL=info

QUANTIFY_DATABASE_URL=__SET_IN_env.local__
QUANTIFY_REDIS_URL=__SET_IN_env.local__
QUANTIFY_APP_SECRET=__SET_IN_env.local__
QUANTIFY_JWT_SECRET=__SET_IN_env.local__
QUANTIFY_UNIAPI_API_KEY=__SET_IN_env.local__
QUANTIFY_EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__
QUANTIFY_PORT=__SET_IN_env.local__
QUANTIFY_BASE_URL=http://127.0.0.1:3010
# QUANTIFY_API_BASE_URL 通常由 QUANTIFY_BASE_URL + NEXT_PUBLIC_API_BASE_URL 推导。
# 只有当 Quantify API 路径和默认 /api/v1 不一致时，才在本地覆盖打开。
#QUANTIFY_API_BASE_URL=http://127.0.0.1:3010/api/v1
BACKEND_API_BASE_URL=__SET_IN_env.local__
MARKET_DATA_TIMEFRAMES=1m,3m,5m,15m,30m,1h,4h,6h,8h,12h,1d,1w

NEXT_PUBLIC_APP_ENV=${APP_ENV}
NEXT_PUBLIC_API_SERVER_URL=https://cfx-backend-staging.devbase.cloud
NEXT_PUBLIC_WS_URL=wss://cfx-backend-staging.devbase.cloud
NEXT_PUBLIC_API_BASE_URL=__SET_IN_env.local__
NEXT_PUBLIC_APP_NAME=Net Web (Staging)
NEXT_PUBLIC_APP_VERSION=0.1.0

FRONTEND_URL=https://cfx-www-staging.devbase.cloud
FRONTEND_REDIRECT_ORIGINS=https://cfx-www-staging.devbase.cloud,https://cfx-admin-staging.devbase.cloud
TELEGRAM_BOT_TOKEN=__SET_IN_env.local__
TELEGRAM_LOGIN_BOT_NAME=__SET_IN_env.local__
TELEGRAM_BOT_WEBHOOK_SECRET=__SET_IN_env.local__

# Socket.IO Gateway 允许的 Origin（逗号分隔）
# 如管理端单独域名部署，请把管理端域名也加进来。
ALLOWED_ORIGINS=https://cfx-www-staging.devbase.cloud,https://cfx-admin-staging.devbase.cloud

RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# Staging 固定邮箱验证码开关
# 作用：仅在 staging 环境下用于联调/验收时快速登录
# 说明：
# 1. 关闭时走真实随机验证码
# 2. 开启时走固定验证码
# 3. 仅建议在 .env.staging.local 中填写真实值，不要在仓库默认文件里启用
STAGING_FIXED_EMAIL_OTP_ENABLED=__SET_IN_env.local__
STAGING_FIXED_EMAIL_OTP_CODE=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_API_KEY=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_BASE_URL=__SET_IN_env.local__
LLM_STRATEGY_CODEGEN_MODEL=__SET_IN_env.local__
TRANSLATE_LLM_API_KEY=__SET_IN_env.local__
TRANSLATE_LLM_BASE_URL=__SET_IN_env.local__
TRANSLATE_LLM_MODEL=__SET_IN_env.local__

EXCHANGE_ACCOUNT_CRYPTO_KEY=__SET_IN_env.local__

# Coinglass
COINGLASS_API_KEY=__SET_IN_env.local__

# BBX API (加密股票报价)
BBX_ACCESS_KEY_ID=__SET_IN_env.local__
BBX_ACCESS_SECRET=__SET_IN_env.local__

#REDIS_DB=0
NEXT_PUBLIC_CDN_DOMAIN=cdn.example.com
NEXT_PUBLIC_DEFAULT_BACKGROUND_IMAGES="none"
# Trades WebSocket ingestion (markets/trades)
# Enable trades WS ingestion (set true to enable)
TRADES_WS_ENABLED=__SET_IN_env.local__

# Sync interval (ms), minimum 1000
TRADES_WS_SYNC_INTERVAL_MS=__SET_IN_env.local__

# OKX trades WS base URL (no path)
# e.g. wss://ws.okx.com:8443
TRADES_OKX_WS_BASE_URL=__SET_IN_env.local__

# Max streams per WS connection (sharding)
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=__SET_IN_env.local__

# Trades retention days (CleanupOldTradesJob)
TRADES_RETENTION_DAYS=__SET_IN_env.local__

# Hyperliquid WebSocket 配置
HYPERLIQUID_API_URL=__SET_IN_env.local__
HYPERLIQUID_TRADES_WS_ENABLED=__SET_IN_env.local__
HYPERLIQUID_WS_URL=__SET_IN_env.local__
HYPERLIQUID_WHALE_REFRESH_INTERVAL_MS=__SET_IN_env.local__

# Whale Notification
WHALE_NOTIFICATION_ENABLED=__SET_IN_env.local__
# 灰度白名单（逗号分隔用户 ID），留空表示全量
WHALE_NOTIFICATION_ALLOWED_USER_IDS=__SET_IN_env.local__
WHALE_NOTIFICATION_COOLDOWN_SECONDS=__SET_IN_env.local__
WHALE_NOTIFICATION_RETRY_MAX_ATTEMPTS=__SET_IN_env.local__
WHALE_NOTIFICATION_RETRY_BACKOFF_MS=__SET_IN_env.local__

# Vercel 部署配置
VERCEL_TOKEN=__SET_IN_env.local__
VERCEL_GIT_COMMIT_AUTHOR_EMAIL=__SET_IN_env.local__
