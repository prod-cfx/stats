{
  "version": 1,
  "environments": ["development", "staging", "production", "test", "e2e"],
  "layout": {
    "forbidExact": [".env", ".env.local"],
    "allowRoot": [".env.{env}", ".env.{env}.local"],
    "allowSubdirGlobs": ["docker/.env*", ".vercel/.env*", "apps/*/.env*", "packages/*/.env*"]
  },
  "secretPlaceholder": "__SET_IN_env.local__",
  "keys": {
    "secret": [
      "POSTGRES_USER",
      "POSTGRES_PASSWORD",
      "DATABASE_URL",
      "QUANTIFY_DATABASE_URL",
      "REDIS_PASSWORD",
      "REDIS_URL",
      "QUANTIFY_REDIS_URL",
      "JWT_SECRET",
      "QUANTIFY_JWT_SECRET",
      "APP_SECRET",
      "QUANTIFY_APP_SECRET",
      "QUANTIFY_UNIAPI_API_KEY",
      "QUANTIFY_EXCHANGE_ACCOUNT_CRYPTO_KEY",
      "RESEND_API_KEY",
      "EMAIL_FROM",
      "EMAIL_FROM_NAME",
      "UNIAPI_API_KEY",
      "LLM_STRATEGY_CODEGEN_API_KEY",
      "EXCHANGE_ACCOUNT_CRYPTO_KEY",
      "VERCEL_TOKEN",
      "VERCEL_GIT_COMMIT_AUTHOR_EMAIL",
      "BBX_ACCESS_KEY_ID",
      "BBX_ACCESS_SECRET",
      "TRANSLATE_LLM_API_KEY"
    ],
    "localOnly": [],
    "localOverride": [
      "POSTGRES_HOST",
      "POSTGRES_PORT",
      "REDIS_HOST",
      "REDIS_PORT",
      "REDIS_DB",
      "LOG_CONTEXT_FILTER",
      "LOG_LEVEL",
      "SEED_INIT_WALLET_BALANCE",
      "FRONTEND_URL",
      "FRONTEND_REDIRECT_ORIGINS",
      "JWT_EXPIRES_IN",
      "JWT_REFRESH_EXPIRES_IN",
      "NEXT_PUBLIC_APP_ENV",
      "NEXT_PUBLIC_API_SERVER_URL",
      "NEXT_PUBLIC_QUANTIFY_API_SERVER_URL",
      "NEXT_PUBLIC_API_BASE_URL",
      "NEXT_PUBLIC_APP_NAME",
      "NEXT_PUBLIC_APP_VERSION",
      "NEXT_PUBLIC_LOG_LEVEL",
      "NEXT_PUBLIC_DEV_BACKEND_PORT",
      "NEXT_PUBLIC_DEV_AUTH_BYPASS",
      "NEXT_PUBLIC_DEFAULT_LOCALE",
      "NEXT_PUBLIC_WS_URL",
      "NEXT_PUBLIC_ENABLE_OI_DEBUG",
      "NEXT_PUBLIC_MOCK_API",
      "NEXT_PUBLIC_ACCOUNT_AI_QUANT_MOCK_FALLBACK",
      "NEXT_PUBLIC_HYPERLIQUID_API_URL",
      "NEXT_PUBLIC_CDN_DOMAIN",
      "NEXT_PUBLIC_DEFAULT_BACKGROUND_IMAGES",
      "HYPERLIQUID_API_URL",
      "UNIAPI_BASE_URL",
      "LLM_STRATEGY_CODEGEN_BASE_URL",
      "LLM_STRATEGY_CODEGEN_MODEL",
      "POLYMARKET_TRANSLATE_ENABLED",
      "POLYMARKET_CATEGORY",
      "POLYMARKET_TAGS",
      "POLYMARKET_GAMMA_TIMEOUT_MS",
      "POLYMARKET_GAMMA_LIMIT",
      "POLYMARKET_CLOB_TIMEOUT_MS",
      "POLYMARKET_GAMMA_BASE_URL",
      "POLYMARKET_CLOB_BASE_URL",
      "POLYMARKET_CLOB_WS_URL",
      "MESSAGEBUS_OUTBOX_DISABLED",
      "VERCEL_ORG_ID",
      "VERCEL_PROJECT_ID_FRONT",
      "VERCEL_PROJECT_ID_ADMIN",
      "METRICS_ENABLED",
      "METRICS_EXPORTER_TYPE",
      "METRICS_PROMETHEUS_PORT",
      "METRICS_PROMETHEUS_ENDPOINT",
      "METRICS_REMOTE_WRITE_ENABLED",
      "METRICS_REMOTE_WRITE_ENDPOINT",
      "METRICS_REMOTE_WRITE_USERNAME",
      "METRICS_REMOTE_WRITE_INTERVAL_MS",
      "METRICS_SERVICE_NAME",
      "METRICS_SERVICE_VERSION",
      "COINGLASS_API_KEY",
      "COINGLASS_AGG_LIQUIDATION_ENDPOINT",
      "COINGLASS_COINS_PRICE_CHANGE_ENDPOINT",
      "COINGLASS_HEATMAP_ENDPOINT",
      "COINGLASS_LONG_SHORT_RATIO_ENDPOINT",
      "COINGLASS_OI_ENDPOINT",
      "COINGLASS_OI_OHLC_ENDPOINT",
      "COINGLASS_PAIRS_MARKETS_ENDPOINT",
      "COINGLASS_WHALE_ALERT_ENDPOINT",
      "BACKFILL_RECHECK_WINDOW_DAYS",
      "USE_MOCK_DATA",
      "SKIP_PRISMA_CONNECT",
      "S3_ACCESS_KEY",
      "S3_SECRET_ID",
      "S3_SECRET_KEY",
      "S3_BUCKET_NAME",
      "S3_REGION",
      "S3_ENDPOINT",
      "S3_CDN_DOMAIN",
      "S3_PRESIGNED_URL_EXPIRATION",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "DISCORD_CLIENT_ID",
      "DISCORD_CLIENT_SECRET",
      "TELEGRAM_BOT_TOKEN",
      "TELEGRAM_LOGIN_BOT_NAME",
      "TELEGRAM_BOT_WEBHOOK_URL",
      "TELEGRAM_BOT_WEBHOOK_SECRET",
      "TELEGRAM_BOT_RECHARGE_URL",
      "TELEGRAM_BOT_ENABLE_PRIVATE",
      "TELEGRAM_BOT_ENABLE_GROUP",
      "TELEGRAM_BOT_DEFAULT_MODEL",
      "TELEGRAM_BOT_SESSION_TTL",
      "TELEGRAM_BOT_RATE_LIMIT",
      "GH_ACCOUNT",
      "POLYMARKET_GAMMA_API_KEY",
      "POLYMARKET_CLOB_API_KEY",
      "OPENAI_COMPATIBLE_API_KEY",
      "OPENAI_COMPATIBLE_BASE_URL",
      "PORT",
      "API_PREFIX",
      "APP_NAME",
      "UPLOAD_DESTINATION",
      "MAX_FILE_SIZE",
      "ALLOWED_FILE_TYPES",
      "ALLOWED_ORIGINS",
      "BCRYPT_SALT_ROUNDS",
      "AUTH_RATE_LIMIT_ENABLED",
      "AUTH_RATE_LIMIT_MAX",
      "AUTH_RATE_LIMIT_FALLBACK_MAX",
      "AUTH_RATE_LIMIT_WINDOW_MS",
      "THROTTLE_TTL",
      "THROTTLE_LIMIT",
      "THROTTLE_IGNORE_USER_AGENTS",
      "THROTTLE_SKIP_IF",
      "THROTTLE_REDIS_ENABLE",
      "MESSAGEBUS_BACKOFF_DELAY_MS",
      "MESSAGEBUS_DEFAULT_MODE",
      "MESSAGEBUS_OUTBOX_POLL_INTERVAL_MS",
      "MESSAGEBUS_OUTBOX_BATCH_SIZE",
      "MESSAGEBUS_OUTBOX_MAX_ATTEMPTS",
      "MESSAGEBUS_OUTBOX_LOCK_TIMEOUT_SEC",
      "MESSAGEBUS_OUTBOX_BASE_BACKOFF_MS",
      "MESSAGEBUS_OUTBOX_RETAIN_DAYS",
      "MESSAGEBUS_OUTBOX_PUBLISH_ATTEMPTS",
      "MESSAGEBUS_OUTBOX_CANDIDATE_FACTOR",
      "MESSAGEBUS_OUTBOX_CLAIM_MAX_CYCLES",
      "USERACTIVITY_DEDUPE_TTL_SEC",
      "ENGAGEMENT_DEDUPE_TTL_SEC",
      "ENGAGEMENT_TIMEZONE",
      "ENGAGEMENT_MAX_DELAY_DAYS",
      "PRISMA_SLOW_QUERY_MS",
      "PRISMA_CRITICAL_SLOW_QUERY_MS",
      "MARKET_DATA_PROVIDER",
      "MARKET_DATA_API_BASE_URL",
      "MARKET_DATA_WS_URL",
      "MARKET_DATA_WS_STREAM_PATH",
      "MARKET_DATA_SPOT_REST_BASE_URL",
      "MARKET_DATA_PERP_REST_BASE_URL",
      "MARKET_DATA_SPOT_WS_BASE_URL",
      "MARKET_DATA_PERP_WS_BASE_URL",
      "MARKET_DATA_SPOT_REST_PATH_TEMPLATE",
      "MARKET_DATA_PERP_REST_PATH_TEMPLATE",
      "MARKET_DATA_SPOT_EXCHANGE_INFO_PATH",
      "MARKET_DATA_PERP_EXCHANGE_INFO_PATH",
      "MARKET_DATA_SPOT_WS_PATH_TEMPLATE",
      "MARKET_DATA_PERP_WS_PATH_TEMPLATE",
      "MARKET_DATA_OKX_REST_BASE_URL",
      "MARKET_DATA_OKX_WS_BASE_URL",
      "MARKET_DATA_HYPERLIQUID_REST_BASE_URL",
      "MARKET_DATA_HYPERLIQUID_WS_BASE_URL",
      "MARKET_DATA_SYMBOLS",
      "MARKET_DATA_TIMEFRAMES",
      "MARKET_DATA_HISTORICAL_LOOKBACK_MINUTES",
      "MARKET_DATA_REST_BATCH_SIZE",
      "MARKET_DATA_WS_RECONNECT_DELAY_MS",
      "MARKET_DATA_REST_TIMEOUT_MS",
      "STRATEGY_SIGNALS_ENABLED",
      "STRATEGY_SIGNALS_CRON",
      "STRATEGY_SIGNALS_EXECUTION_ENABLED",
      "STRATEGY_SIGNALS_EXECUTION_DRY_RUN",
      "MARKET_DATA_ORDERBOOK_SNAPSHOT_BATCH_SIZE",
      "ORDERBOOK_WS_SYNC_INTERVAL_MS",
      "ORDERBOOK_WS_ENABLED",
      "TRADES_WS_SYNC_INTERVAL_MS",
      "TRADES_OKX_WS_BASE_URL",
      "TRADES_OKX_MAX_STREAMS_PER_CONNECTION",
      "TRADES_RETENTION_DAYS",
      "TRADES_WS_ENABLED",
      "HYPERLIQUID_TRADES_WS_ENABLED",
      "HYPERLIQUID_WS_URL",
      "HYPERLIQUID_WHALE_REFRESH_INTERVAL_MS",
      "WHALE_NOTIFICATION_ENABLED",
      "WHALE_NOTIFICATION_ALLOWED_USER_IDS",
      "WHALE_NOTIFICATION_COOLDOWN_SECONDS",
      "WHALE_NOTIFICATION_RETRY_MAX_ATTEMPTS",
      "WHALE_NOTIFICATION_RETRY_BACKOFF_MS",
      "KLINE_TICKER_E2E",
      "HYPERLIQUID_ORDERBOOK_WS_ENABLED",
      "JWT_ACCESS_EXPIRATION",
      "HTTP_TRUST_PROXY",
      "HTTP_TRUST_PROXY_HOPS",
      "TRUST_PROXY",
      "TRANSLATE_LLM_BASE_URL",
      "TRANSLATE_LLM_MODEL",
      "QUANTIFY_APP_NAME",
      "QUANTIFY_API_BASE_URL",
      "QUANTIFY_HTTP_TIMEOUT_MS",
      "QUANTIFY_PORT",
      "QUANTIFY_BASE_URL",
      "QUANTIFY_AI_MOCK_ENABLED",
      "QUANTIFY_CODEGEN_MOCK_ONLY"
    ]
  },
  "appToTarget": {
    "backend": "backend",
    "quantify": "quantify",
    "front": "frontend",
    "admin-front": "frontend"
  },
  "targets": {
    "backend": {
      "files": {
        "committed": ".env.{env}",
        "local": ".env.{env}.local"
      },
      "required": {
        "_common": ["APP_ENV"],
        "development": ["DATABASE_URL", "REDIS_URL", "APP_SECRET", "JWT_SECRET"],
        "staging": ["DATABASE_URL", "REDIS_URL", "APP_SECRET", "JWT_SECRET"],
        "production": ["DATABASE_URL", "REDIS_URL", "APP_SECRET", "JWT_SECRET"],
        "e2e": ["DATABASE_URL", "REDIS_URL", "APP_SECRET", "JWT_SECRET", "EXCHANGE_ACCOUNT_CRYPTO_KEY"]
      }
    },
    "quantify": {
      "files": {
        "committed": ".env.{env}",
        "local": ".env.{env}.local"
      },
      "required": {
        "_common": ["APP_ENV"],
        "development": [
          "QUANTIFY_DATABASE_URL",
          "QUANTIFY_REDIS_URL",
          "QUANTIFY_APP_SECRET",
          "QUANTIFY_JWT_SECRET"
        ],
        "staging": [
          "QUANTIFY_DATABASE_URL",
          "QUANTIFY_REDIS_URL",
          "QUANTIFY_APP_SECRET",
          "QUANTIFY_JWT_SECRET"
        ],
        "production": [
          "QUANTIFY_DATABASE_URL",
          "QUANTIFY_REDIS_URL",
          "QUANTIFY_APP_SECRET",
          "QUANTIFY_JWT_SECRET"
        ],
        "e2e": [
          "QUANTIFY_DATABASE_URL",
          "QUANTIFY_REDIS_URL",
          "QUANTIFY_APP_SECRET",
          "QUANTIFY_JWT_SECRET",
          "QUANTIFY_EXCHANGE_ACCOUNT_CRYPTO_KEY"
        ]
      }
    },
    "frontend": {
      "files": {
        "committed": ".env.{env}",
        "local": ".env.{env}.local"
      },
      "required": {
        "_common": []
      }
    }
  }
}
