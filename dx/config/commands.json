{
  "dev": {
    "backend": {
      "command": "npx nx dev backend",
      "app": "backend",
      "ports": [3000],
      "description": "启动后端开发服务"
    },
    "front": {
      "command": "npx nx dev front",
      "app": "front",
      "ports": [3001],
      "description": "启动前端开发服务"
    },
    "admin": {
      "command": "npx nx dev admin-front",
      "app": "admin-front",
      "ports": [3500],
      "description": "启动管理后台开发服务"
    },
    "all": {
      "concurrent": true,
      "commands": ["dev.backend", "dev.front", "dev.admin"],
      "description": "同时启动所有开发服务",
      "interactive": true
    }
  },

  "install": {
    "command": "pnpm install --frozen-lockfile",
    "description": "安装依赖"
  },

  "build": {
    "backend": {
      "dev": {
        "command": "npx nx build backend --configuration=development",
        "app": "backend",
        "description": "构建后端(开发环境)"
      },
      "prod": {
        "command": "npx nx build backend --configuration=production",
        "app": "backend",
        "description": "构建后端(生产环境)"
      }
    },
    "quantify": {
      "skipEnvValidation": true,
      "dev": {
        "command": "npx nx build quantify --configuration=development",
        "app": "quantify",
        "skipEnvValidation": true,
        "description": "构建 Quantify(开发环境)"
      },
      "prod": {
        "command": "npx nx build quantify --configuration=production",
        "app": "quantify",
        "skipEnvValidation": true,
        "description": "构建 Quantify(生产环境)"
      }
    },
    "shared": {
      "command": "npx nx build shared",
      "description": "构建共享包 @ai/shared"
    },
    "front": {
      "dev": {
        "command": "npx nx build front --configuration=development",
        "app": "front",
        "description": "构建前端(开发环境)"
      },
      "prod": {
        "command": "npx nx run front:exportDist",
        "app": "front",
        "description": "构建并导出前端到 dist/front (生产环境)"
      }
    },
    "admin": {
      "dev": {
        "command": "npx nx build admin-front --configuration=development",
        "app": "admin-front",
        "description": "构建管理后台(开发环境)"
      },
      "prod": {
        "command": "npx nx build admin-front --configuration=production",
        "app": "admin-front",
        "description": "构建管理后台(生产环境)"
      }
    },
    "all": {
      "dev": {
        "sequential": true,
        "commands": ["build.backend.dev", "build.quantify.dev", "build.contracts", "build.parallelWeb.dev"],
        "description": "构建所有应用(开发环境，含 contracts，Web并行)"
      },
      "prod": {
        "sequential": true,
        "commands": ["build.backend.prod", "build.quantify.prod", "build.contracts", "build.parallelWeb.prod"],
        "description": "构建所有应用(生产环境，Web并行)"
      }
    },
    "parallelWeb": {
      "dev": {
        "concurrent": true,
        "commands": ["build.shared", "build.front.dev", "build.admin.dev"],
        "description": "并行构建 Web（shared/front/admin 开发环境）"
      },
      "prod": {
        "concurrent": true,
        "commands": ["build.shared", "build.front.prod", "build.admin.prod"],
        "description": "并行构建 Web（shared/front/admin 生产环境）"
      }
    },
    "affected": {
      "dev": {
        "command": "npx nx affected -t build --configuration=development --parallel=3",
        "description": "仅构建受影响项目(开发环境)"
      },
      "prod": {
        "command": "npx nx affected -t build --configuration=production --parallel=3",
        "description": "仅构建受影响项目(生产环境)"
      }
    },
    "contracts": {
      "command": "bash -lc 'set -euo pipefail; npx nx run backend:swagger; node scripts/generate-backend-contracts.mjs'",
      "app": "backend",
      "description": "生成 API 合约 (packages/api-contracts)"
    }
  },

  "db": {
    "generate": {
      "command": "pnpm --filter @net/backend run prisma:generate",
      "app": "backend",
      "description": "生成Prisma客户端",
      "quantify": {
        "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:generate",
        "app": "quantify",
        "skipEnvValidation": true,
        "description": "生成 Quantify Prisma 客户端"
      }
    },
    "migrate": {
      "dev": {
        "command": "pnpm --filter @net/backend run prisma:migrate:dev",
        "app": "backend",
        "description": "创建数据库迁移(开发环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:migrate:dev",
          "app": "quantify",
          "skipEnvValidation": true,
          "description": "创建 Quantify 数据库迁移(开发环境)"
        }
      }
    },
    "deploy": {
      "dev": {
        "command": "pnpm --filter @net/backend run prisma:migrate:deploy",
        "app": "backend",
        "description": "应用数据库迁移(开发环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:migrate:deploy",
          "app": "quantify",
          "skipEnvValidation": true,
          "description": "应用 Quantify 数据库迁移(开发环境)"
        }
      },
      "test": {
        "command": "pnpm --filter @net/backend run prisma:migrate:deploy",
        "app": "backend",
        "description": "应用数据库迁移(测试环境)"
      },
      "e2e": {
        "command": "pnpm --filter @net/backend run prisma:migrate:deploy",
        "app": "backend",
        "description": "应用数据库迁移(E2E环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:migrate:deploy",
          "app": "quantify",
          "skipEnvValidation": true,
          "description": "应用 Quantify 数据库迁移(E2E环境)"
        }
      },
      "prod": {
        "command": "pnpm --filter @net/backend run prisma:migrate:deploy",
        "app": "backend",
        "dangerous": true,
        "description": "应用数据库迁移(生产/预发环境)"
      }
    },
    "reset": {
      "dev": {
        "command": "pnpm --filter @net/backend run prisma:migrate:reset",
        "app": "backend",
        "dangerous": true,
        "description": "重置数据库(开发环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:db:reset",
          "app": "quantify",
          "dangerous": true,
          "skipEnvValidation": true,
          "description": "重置 Quantify 数据库(开发环境)"
        }
      },
      "e2e": {
        "command": "pnpm --filter @net/backend run prisma:migrate:reset",
        "app": "backend",
        "dangerous": true,
        "description": "重置数据库(E2E环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:migrate:reset",
          "app": "quantify",
          "dangerous": true,
          "skipEnvValidation": true,
          "description": "重置 Quantify 数据库(E2E环境)"
        }
      },
      "prod": {
        "command": "pnpm --filter @net/backend run prisma:migrate:reset",
        "app": "backend",
        "dangerous": true,
        "description": "重置数据库(生产环境)"
      }
    },
    "seed": {
      "dev": {
        "command": "pnpm --filter @net/backend run prisma:db:seed",
        "app": "backend",
        "description": "填充种子数据(开发环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:db:seed",
          "app": "quantify",
          "skipEnvValidation": true,
          "description": "填充 Quantify 种子数据(开发环境)"
        }
      },
      "e2e": {
        "command": "pnpm --filter @net/backend run prisma:db:seed",
        "app": "backend",
        "description": "填充种子数据(E2E环境)",
        "quantify": {
          "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:db:seed",
          "app": "quantify",
          "skipEnvValidation": true,
          "description": "填充 Quantify 种子数据(E2E环境)"
        }
      },
      "prod": {
        "command": "pnpm --filter @net/backend run prisma:db:seed",
        "app": "backend",
        "dangerous": true,
        "description": "填充种子数据(生产环境)"
      }
    },
    "format": {
      "command": "pnpm --filter @net/backend run prisma:format",
      "description": "格式化Prisma schema文件",
      "quantify": {
        "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter @net/quantify run prisma:format",
        "app": "quantify",
        "skipEnvValidation": true,
        "description": "格式化 Quantify Prisma schema 文件"
      }
    },
    "script": {
      "dev": {
        "command": "pnpm --filter @net/backend exec tsx prisma/scripts/{SCRIPT_NAME}.ts",
        "app": "backend",
        "description": "执行数据库脚本(开发环境)"
      },
      "e2e": {
        "command": "pnpm --filter @net/backend exec tsx prisma/scripts/{SCRIPT_NAME}.ts",
        "app": "backend",
        "description": "执行数据库脚本(E2E环境)"
      },
      "prod": {
        "command": "pnpm --filter @net/backend exec tsx prisma/scripts/{SCRIPT_NAME}.ts",
        "app": "backend",
        "dangerous": true,
        "description": "执行数据库脚本(生产环境)"
      }
    }
  },

  "test": {
    "e2e": {
      "backend": {
        "command": "npx nx test:e2e backend",
        "app": "backend",
        "requiresPath": true,
        "fileCommand": "npx nx test:e2e backend -- {TEST_PATH}",
        "description": "运行后端E2E测试"
      },
      "quantify": {
        "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter ./apps/quantify run test:e2e",
        "app": "quantify",
        "description": "运行 Quantify E2E 测试",
        "requiresPath": true,
        "fileCommand": "node scripts/dx/quantify-launcher.cjs pnpm --filter ./apps/quantify run test:e2e:file {TEST_PATH}",
        "skipEnvValidation": true
      },
      "all": {
        "command": "npx nx test:e2e backend",
        "app": "backend",
        "description": "保留占位；CLI 层已禁止 E2E 全量聚合执行"
      }
    },
    "unit": {
      "backend": {
        "command": "npx nx test backend",
        "app": "backend",
        "description": "运行后端单元测试"
      },
      "quantify": {
        "command": "node scripts/dx/quantify-launcher.cjs npx nx test quantify",
        "app": "quantify",
        "description": "运行 Quantify 单元测试",
        "skipEnvValidation": true
      }
    }
  },

  "lint": {
    "command": "npx nx run-many -t lint",
    "description": "运行代码检查",
    "skipEnvValidation": true
  },

  "start": {
    "backend": {
      "dev": {
        "command": "pnpm --filter ./apps/backend run dev",
        "app": "backend",
        "description": "启动后端开发服务（tsx watch，支持热重载）"
      },
      "prod": {
        "command": "npx nx start backend",
        "app": "backend",
        "description": "启动后端生产服务"
      }
    },
    "quantify": {
      "skipEnvValidation": true,
      "dev": {
        "command": "node scripts/dx/quantify-launcher.cjs pnpm --filter ./apps/quantify run dev",
        "app": "quantify",
        "ports": [3010],
        "skipEnvValidation": true,
        "description": "启动 Quantify 开发服务"
      },
      "prod": {
        "command": "node scripts/dx/quantify-launcher.cjs npx nx start quantify",
        "app": "quantify",
        "skipEnvValidation": true,
        "description": "启动 Quantify 生产服务"
      }
    },
    "front": {
      "dev": {
        "command": "npx nx dev front",
        "app": "front",
        "ports": [3001],
        "description": "启动前端开发服务"
      },
      "prod": {
        "command": "npx nx start front",
        "app": "front",
        "description": "启动前端生产服务"
      }
    },
    "admin": {
      "dev": {
        "command": "npx nx dev admin-front",
        "app": "admin-front",
        "ports": [3500],
        "description": "启动管理后台开发服务"
      },
      "prod": {
        "command": "npx nx start admin-front",
        "app": "admin-front",
        "description": "启动管理后台生产服务"
      }
    },
    "all": {
      "concurrent": true,
      "commands": ["start.backend.dev", "start.front.dev", "start.admin.dev"],
      "description": "同时启动所有服务",
      "interactive": true
    },
    "dev": {
      "internal": "start-dev",
      "args": [],
      "description": "启动完整开发环境（集成start-dev.sh功能）",
      "interactive": true
    },
    "stack": {
      "internal": "pm2-stack",
      "interactive": true,
      "description": "PM2 交互式服务栈（服务、端口清理、缓存清理均可配置）",
      "stack": {
        "ecosystemConfig": "ecosystem.config.cjs",
        "pm2Bin": "pnpm pm2",
        "services": [
          "backend",
          "front",
          "admin",
          "quantify"
        ],
        "preflight": {
          "pm2Reset": true,
          "killPorts": [
            3000,
            3001,
            3500,
            3010
          ],
          "forcePortCleanup": true,
          "cleanPaths": [
            "apps/front/.next",
            "dist/front",
            "apps/front/.eslintcache",
            "apps/admin-front/node_modules/.vite",
            "dist/admin-front",
            "apps/admin-front/.eslintcache",
            "apps/quantify/dist",
            "apps/quantify/.eslintcache"
          ],
          "cleanTsBuildInfo": true,
          "cleanTsBuildInfoDirs": [
            "apps/front",
            "apps/admin-front",
            "apps/quantify"
          ]
        }
      }
    },
    "stagewise-front": {
      "command": "npx stagewise@latest -b -a 3001 -p 3002 -w ./apps/front",
      "description": "Stagewise 桥接 front (3001→3002)",
      "ports": [3002]
    },
    "stagewise-admin": {
      "command": "npx stagewise@latest -b -s -a 3500 -p 3501 -w ./apps/admin-front",
      "description": "Stagewise 桥接 admin-front (3500→3501)",
      "ports": [3501]
    },
    "mock": {
      "command": "pnpm --filter @ai/front run dev:mock",
      "app": "front",
      "ports": [3001],
      "description": "启动前端开发服务(Mock后端)"
    }
  },

  "clean": {
    "all": {
      "command": "npx nx run-many -t clean",
      "description": "清理所有构建文件"
    },
    "deps": {
      "command": "rm -rf node_modules && pnpm install",
      "description": "清理并重新安装依赖",
      "dangerous": true
    }
  },

  "cache": {
    "clear": {
      "command": "set -e; npx nx reset; pnpm store prune || true; STORE_PATH=$(pnpm store path 2>/dev/null || echo ''); if [ -n \"$STORE_PATH\" ] && [ -d \"$STORE_PATH\" ]; then echo \"移除 PNPM store: $STORE_PATH\"; rm -rf \"$STORE_PATH\"; fi; rm -rf .nx/cache node_modules/.cache ~/.pnpm-store || true; echo 'Nx 与依赖缓存已清理'",
      "description": "清除 Nx 缓存与依赖库缓存 (pnpm store / 本地缓存)",
      "dangerous": true
    }
  },

  "demo": {},
  "deploy": {
    "backend": {
      "internal": "backend-artifact-deploy",
      "description": "构建、上传并部署 backend 制品到远端主机",
      "backendDeploy": {
        "build": {
          "app": "backend",
          "distDir": "dist/backend",
          "versionFile": "apps/backend/package.json",
          "commands": {
            "development": "npx nx build backend --configuration=development",
            "staging": "npx nx build backend --configuration=production",
            "production": "npx nx build backend --configuration=production"
          }
        },
        "runtime": {
          "appPackage": "dist/backend/package.json",
          "rootPackage": "package.json",
          "lockfile": "pnpm-lock.yaml",
          "prismaSchemaDir": "apps/backend/prisma/schema",
          "prismaConfig": "apps/backend/prisma.config.ts",
          "ecosystemConfig": "dx/deploy/ecosystem.backend.config.cjs"
        },
        "artifact": {
          "outputDir": "release/backend",
          "bundleName": "backend-bundle"
        },
        "remote": {
          "host": "stats-server",
          "port": 22,
          "user": "root",
          "baseDir": "/opt/stats"
        },
        "startup": {
          "mode": "pm2",
          "serviceName": "backend"
        },
        "deploy": {
          "keepReleases": 5,
          "installCommand": "CI=true pnpm install --prod --no-frozen-lockfile --ignore-workspace",
          "prismaGenerate": true,
          "prismaMigrateDeploy": true,
          "prismaSeed": true
        }
      }
    },
    "quantify": {
      "internal": "backend-artifact-deploy",
      "description": "构建、上传并部署 quantify 制品到远端主机",
      "backendDeploy": {
        "build": {
          "app": "quantify",
          "distDir": "dist/quantify",
          "versionFile": "apps/quantify/package.json",
          "commands": {
            "development": "npx nx build quantify --configuration=development",
            "staging": "npx nx build quantify --configuration=production",
            "production": "npx nx build quantify --configuration=production"
          }
        },
        "runtime": {
          "appPackage": "dist/quantify/package.json",
          "rootPackage": "package.json",
          "lockfile": "pnpm-lock.yaml",
          "prismaSchemaDir": "apps/quantify/prisma/schema",
          "prismaConfig": "apps/quantify/prisma.config.ts",
          "ecosystemConfig": "dx/deploy/ecosystem.quantify.config.cjs"
        },
        "artifact": {
          "outputDir": "release/quantify",
          "bundleName": "quantify-bundle"
        },
        "remote": {
          "host": "stats-server",
          "port": 22,
          "user": "root",
          "baseDir": "/opt/stats"
        },
        "startup": {
          "mode": "pm2",
          "serviceName": "quantify"
        },
        "deploy": {
          "keepReleases": 5,
          "installCommand": "CI=true pnpm install --prod --no-frozen-lockfile --ignore-workspace",
          "prismaGenerate": true,
          "prismaMigrateDeploy": true,
          "prismaSeed": false
        }
      }
    },
    "front": {
      "staging": {
        "command": "vercel deploy --yes --local-config vercel.front.json",
        "app": "front",
        "description": "部署 front 到 Vercel（预发环境）"
      },
      "prod": {
        "command": "vercel deploy --yes --prod --local-config vercel.front.json",
        "app": "front",
        "description": "部署 front 到 Vercel（生产环境）"
      }
    },
    "admin": {
      "staging": {
        "command": "vercel deploy --yes --local-config vercel.admin.json",
        "app": "admin-front",
        "description": "部署 admin 到 Vercel（预发环境）"
      },
      "prod": {
        "command": "vercel deploy --yes --prod --local-config vercel.admin.json",
        "app": "admin-front",
        "description": "部署 admin 到 Vercel（生产环境）"
      }
    },
    "all": {
      "sequential": true,
      "commands": ["deploy.backend", "deploy.quantify", "deploy.front", "deploy.admin"],
      "description": "依次部署所有应用（backend → quantify → front → admin）"
    }
  }
}
