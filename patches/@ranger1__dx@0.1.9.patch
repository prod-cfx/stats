+  resolveConfigForEnvironment(config, envKey) {
+    if (!config || typeof config !== 'object' || config.command || config.internal) {
+      return config
+    }
+    if (config[envKey]) return config[envKey]
+    if (envKey === 'staging' && config.prod) return config.prod
+    return config.dev || config
+  }
+
+  resolveDbTarget(action, token, envKey = this.normalizeEnvKey(this.determineEnvironment())) {
+    if (!action || !token || action === 'script') return null
+
+    const actionConfig = this.commands?.db?.[action]
+    if (!actionConfig || typeof actionConfig !== 'object') return null
+
+    if (actionConfig[token]) return token
+
+    const scopedConfig = this.resolveConfigForEnvironment(actionConfig, envKey)
+    if (scopedConfig?.[token]) return token
+
+    return null
+  }
+
+  resolveDbConfig(action, target = null, envKey = this.normalizeEnvKey(this.determineEnvironment())) {
+    if (!action) return null
+
+    let config = this.commands?.db?.[action]
+    if (!config) return null
+
+    if (target) {
+      config = config[target] || this.resolveConfigForEnvironment(config, envKey)?.[target]
+    }
+
+    return this.resolveConfigForEnvironment(config, envKey)
+  }
+
+  resolveCurrentCommandConfig() {
+    const cleanArgs = getCleanArgs(this.args)
+    const command = cleanArgs[0]
+    const envKey = this.normalizeEnvKey(this.determineEnvironment())
+
+    switch (command) {
+      case 'start': {
+        const service = cleanArgs[1] || 'dev'
+        const raw = this.commands.start?.[service] || this.commands.dev?.[service]
+        return this.resolveConfigForEnvironment(raw, envKey)
+      }
+      case 'build': {
+        const target = cleanArgs[1] || 'all'
+        return this.resolveConfigForEnvironment(this.commands.build?.[target], envKey)
+      }
+      case 'test': {
+        const type = cleanArgs[1] || 'e2e'
+        const target = cleanArgs[2] || 'all'
+        const raw = this.commands.test?.[type]?.[target] || this.commands.test?.[type]
+        return this.resolveConfigForEnvironment(raw, envKey)
+      }
+      case 'db': {
+        const action = cleanArgs[1]
+        const target = this.resolveDbTarget(action, cleanArgs[2], envKey)
+        return this.resolveDbConfig(action, target, envKey)
+      }
+      default:
+        return this.getCommandConfig(command)
+    }
+  }
