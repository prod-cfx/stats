# 开发环境全局变量
APP_ENV=development

# 数据库（真实值写入 .env.development.local）
POSTGRES_HOST=__SET_IN_env.local__
POSTGRES_PORT=5432
POSTGRES_USER=__SET_IN_env.local__
POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

# Redis
REDIS_HOST=__SET_IN_env.local__
REDIS_PORT=6379
REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

# JWT
JWT_SECRET=__SET_IN_env.local__
JWT_EXPIRES_IN=30d

# 通用
APP_SECRET=__SET_IN_env.local__
LOG_LEVEL=debug

# 前端
NEXT_PUBLIC_APP_ENV=${APP_ENV}
NEXT_PUBLIC_API_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=Net Web
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_LOG_LEVEL=DEBUG
NEXT_PUBLIC_DEV_BACKEND_PORT=3000

# 后端跨域
FRONTEND_URL=http://localhost:3001
FRONTEND_REDIRECT_ORIGINS=http://localhost:3001,http://localhost:3500,http://localhost:4173

# 邮件
RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__

STRATEGY_SIGNALS_ENABLED=true
UNIAPI_BASE_URL=__SET_IN_env.local__
ORDERBOOK_OKX_SNAPSHOT_ENABLED=true
ORDERBOOK_WS_ENABLED=true
TRADES_WS_ENABLED=true
