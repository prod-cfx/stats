# 开发环境全局变量
APP_ENV=development

# 数据库（真实值写入 .env.development.local）
POSTGRES_HOST=__SET_IN_env.local__
POSTGRES_PORT=5432
POSTGRES_USER=__SET_IN_env.local__
POSTGRES_PASSWORD=__SET_IN_env.local__
DATABASE_URL=__SET_IN_env.local__

# Redis
REDIS_HOST=__SET_IN_env.local__
REDIS_PORT=6379
REDIS_PASSWORD=__SET_IN_env.local__
REDIS_URL=__SET_IN_env.local__

# JWT
JWT_SECRET=__SET_IN_env.local__
JWT_EXPIRES_IN=30d

# 通用
APP_SECRET=__SET_IN_env.local__
LOG_LEVEL=debug

# 前端
NEXT_PUBLIC_APP_ENV=${APP_ENV}
NEXT_PUBLIC_API_SERVER_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
NEXT_PUBLIC_APP_NAME=Net Web
NEXT_PUBLIC_APP_VERSION=0.1.0
NEXT_PUBLIC_LOG_LEVEL=DEBUG
NEXT_PUBLIC_DEV_BACKEND_PORT=3000

# 后端跨域
FRONTEND_URL=http://localhost:3001
FRONTEND_REDIRECT_ORIGINS=http://localhost:3001,http://localhost:3500,http://localhost:4173

# 邮件
RESEND_API_KEY=__SET_IN_env.local__
EMAIL_FROM=__SET_IN_env.local__
EMAIL_FROM_NAME=__SET_IN_env.local__

# AI / LLM Provider
UNIAPI_API_KEY=__SET_IN_env.local__
UNIAPI_BASE_URL=https://api.deepseek.com

# Polymarket 配置
POLYMARKET_CATEGORY=
POLYMARKET_TAGS=
POLYMARKET_GAMMA_TIMEOUT_MS=
POLYMARKET_GAMMA_LIMIT=
POLYMARKET_CLOB_TIMEOUT_MS=
# Polymarket API Keys（敏感，在 .local 配置）
POLYMARKET_GAMMA_API_KEY=__SET_IN_env.local__
POLYMARKET_CLOB_API_KEY=__SET_IN_env.local__
# Polymarket URLs（可选，不填则使用默认）
POLYMARKET_CLOB_BASE_URL=
POLYMARKET_GAMMA_BASE_URL=
POLYMARKET_CLOB_WS_URL=

# Coinglass
COINGLASS_HEATMAP_ENDPOINT=

# BBX
BBX_ACCESS_KEY_ID=__SET_IN_env.local__
BBX_ACCESS_SECRET=__SET_IN_env.local__

# Strategy & Orderbook
STRATEGY_SIGNALS_ENABLED=true
ORDERBOOK_OKX_SNAPSHOT_ENABLED=true
ORDERBOOK_WS_ENABLED=true
ORDERBOOK_BITMAX_ENABLED=true

# Hyperliquid Orderbook WebSocket
HYPERLIQUID_ORDERBOOK_WS_ENABLED=true
HYPERLIQUID_WS_URL=wss://api.hyperliquid.xyz/ws

# Trades WebSocket ingestion
TRADES_WS_ENABLED=false
TRADES_WS_SYNC_INTERVAL_MS=1000
TRADES_OKX_WS_BASE_URL=wss://ws.okx.com:8443
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=100
TRADES_RETENTION_DAYS=7
