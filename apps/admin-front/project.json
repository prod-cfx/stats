{
  "name": "admin-front",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/admin-front/src",
  "projectType": "application",
  "tags": ["scope:admin", "type:app", "framework:nextjs"],
  "implicitDependencies": ["api-contracts", "shared", "config"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/admin-front"],
      "defaultConfiguration": "production",
      "options": {
        "command": "NODE_ENV=production next build",
        "cwd": "apps/admin-front"
      },
      "configurations": {
        "development": {
          "command": "NODE_ENV=production next build",
          "cwd": "apps/admin-front"
        },
        "production": {
          "command": "NODE_ENV=production next build",
          "cwd": "apps/admin-front"
        }
      }
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev -H 0.0.0.0 -p 3500",
        "cwd": "apps/admin-front"
      },
      "dependsOn": ["^build"]
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "command": "next dev -H 0.0.0.0 -p 3500",
        "cwd": "apps/admin-front"
      },
      "dependsOn": ["^build"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start -p 3500",
        "cwd": "apps/admin-front"
      },
      "dependsOn": ["build"]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/admin-front/**/*.{ts,tsx,js,jsx}"],
        "eslintConfig": "eslint.config.js"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "jest --config jest.config.ts",
        "cwd": "apps/admin-front"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit --skipLibCheck --incremental false",
        "cwd": "apps/admin-front"
      }
    }
  }
}
