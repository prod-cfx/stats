{
  "name": "@net/backend",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS 应用骨架",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only=false --project tsconfig.json -r tsconfig-paths/register src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc --project tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:db:seed": "prisma db seed",
    "prisma:format": "prisma format",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\" --config ../../eslint.config.js",
    "test": "echo \"backend tests 尚未配置\"",
    "test:e2e": "jest --config ./e2e/jest-e2e.json --runInBand --forceExit",
    "test:e2e:file": "jest --config ./e2e/jest-e2e.json --runInBand --forceExit"
  },
  "dependencies": {
    "@ai/shared": "workspace:*",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.5",
    "@nestjs/config": "^4.0.1",
    "@nestjs/core": "^11.1.5",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.0",
    "@nestjs/platform-express": "^11.1.5",
    "@nestjs/schedule": "^6.0.1",
    "@nestjs/swagger": "^11.2.1",
    "@nestjs/throttler": "^6.4.0",
    "@net/config": "workspace:*",
    "@nktkas/hyperliquid": "^0.27.1",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.1",
    "ajv": "^8.17.1",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "dotenv-expand": "^12.0.3",
    "ethers": "^6.15.0",
    "ioredis": "^5.7.0",
    "nest-access-control": "^2.2.0",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^5.4.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.4.2",
    "rxjs": "^7.8.1",
    "winston": "^3.17.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@nestjs/schematics": "^11.0.7",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^4.17.23",
    "@types/passport-jwt": "^3.0.9",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prisma": "7.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2"
  }
}
