{
  "name": "@net/backend",
  "version": "0.1.0",
  "private": true,
  "description": "NestJS 应用骨架",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only=false --project tsconfig.json -r tsconfig-paths/register src/main.ts",
    "start": "TS_NODE_BASEURL=./dist node -r tsconfig-paths/register dist/apps/backend/src/main.js",
    "build": "tsc --project tsconfig.json && tsc-alias -p tsconfig.json && node ../../scripts/copy-prisma-client-to-dist.cjs backend && pnpm run postbuild",
    "postbuild": "node ../../scripts/runtime/generate-backend-runtime-package.mjs --app-package ./package.json --root-package ../../package.json --output ./dist/package.json --include-pnpm && xattr -cr dist prisma/schema prisma.config.ts ../../pnpm-lock.yaml ../../dx/deploy 2>/dev/null || true",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:migrate:reset": "prisma migrate reset --force",
    "prisma:db:seed": "prisma db seed",
    "repair:public-data-tasks": "tsx prisma/scripts/repair-public-data-tasks.ts",
    "prisma:format": "prisma format",
    "lint": "eslint \"src/**/*.ts\" \"e2e/**/*.ts\" --config ../../eslint.config.js",
    "test": "jest --config ./jest-unit.json --runInBand",
    "test:e2e": "jest --config ./e2e/jest-e2e.json --runInBand --forceExit",
    "test:e2e:file": "jest --config ./e2e/jest-e2e.json --runInBand --forceExit",
    "diagnose:kline": "tsx scripts/diagnose-kline-gap.ts"
  },
  "dependencies": {
    "@ai/shared": "workspace:*",
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-prisma": "^1.3.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.16",
    "@net/config": "workspace:*",
    "@nktkas/hyperliquid": "^0.27.1",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@prisma/client-runtime-utils": "^7.5.0",
    "ajv": "^8.18.0",
    "async-mutex": "^0.5.0",
    "bcrypt": "^6.0.0",
    "chalk": "^4.1.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.6.1",
    "dotenv-expand": "^12.0.3",
    "ethers": "^6.15.0",
    "ioredis": "^5.7.0",
    "lru-cache": "^11.2.4",
    "nest-access-control": "^2.2.0",
    "nest-winston": "^1.10.2",
    "nestjs-cls": "^6.2.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.16.3",
    "playwright": "^1.57.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.4.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "winston": "^3.17.0",
    "ws": "^8.18.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.16",
    "@types/express": "^4.17.23",
    "@types/passport-jwt": "^3.0.9",
    "@types/pg": "8.11.11",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "jest": "^29.7.0",
    "jest-circus": "^29.7.0",
    "prisma": "7.5.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.4.1",
    "ts-node-dev": "^2.0.0",
    "tsc-alias": "^1.8.16",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.9.2"
  }
}
