/// 用户与认证相关模型
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  nickname        String?
  avatarUrl       String?   @map("avatar_url")
  bio             String?   @db.Text
  invitationCode  String?   @map("invitation_code")
  inviterId       String?   @map("inviter_id")
  isGuest         Boolean   @default(false) @map("is_guest")
  emailVerified   Boolean   @default(false) @map("email_verified")
  emailVerifiedAt DateTime? @map("email_verified_at")
  tokenVersion    Int       @default(0) @map("token_version")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  inviter                     User?                       @relation("UserInviter", fields: [inviterId], references: [id])
  invitedUsers                User[]                      @relation("UserInviter")
  credentials                 UserCredential[]
  betaCodeRedemptions         BetaAccessCodeRedemption[]
  whaleNotificationRules      WhaleNotificationRule[]
  whaleNotificationDeliveries WhaleNotificationDelivery[]

  @@map("users")
}

model BetaAccessCode {
  id               String                     @id @default(cuid())
  code             String                     @unique
  maxUses          Int                        @map("max_uses")
  usedCount        Int                        @default(0) @map("used_count")
  isActive         Boolean                    @default(true) @map("is_active")
  createdByAdminId String?                    @map("created_by_admin_id")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @default(now()) @updatedAt @map("updated_at")
  redemptions      BetaAccessCodeRedemption[]

  @@index([isActive, createdAt], map: "idx_beta_access_codes_active_created")
  @@map("beta_access_codes")
}

model BetaAccessCodeRedemption {
  id        String   @id @default(cuid())
  codeId    String   @map("code_id")
  userId    String   @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  code BetaAccessCode @relation(fields: [codeId], references: [id], onDelete: Restrict)
  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId], map: "uniq_beta_access_code_redemptions_user")
  @@index([codeId], map: "idx_beta_access_code_redemptions_code")
  @@map("beta_access_code_redemptions")
}

model UserCredential {
  id        String             @id @default(cuid())
  userId    String             @map("user_id")
  type      UserCredentialType
  value     String
  createdAt DateTime           @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([type, value], map: "uniq_user_credentials_type_value")
  @@index([userId], map: "idx_user_credentials_user")
  @@map("user_credentials")
}

enum UserCredentialType {
  email
}

model VerificationCode {
  id         String                  @id @default(cuid())
  email      String
  code       String
  purpose    VerificationCodePurpose
  expiresAt  DateTime                @map("expires_at")
  consumedAt DateTime?               @map("consumed_at")
  createdAt  DateTime                @default(now()) @map("created_at")

  @@index([email, purpose], map: "idx_verification_code_email_purpose")
  @@index([code, purpose], map: "idx_verification_code_code_purpose")
  @@map("verification_codes")
}

enum VerificationCodePurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum WhaleNotificationRuleType {
  ADDRESS
  SYMBOL
}

enum WhaleNotificationChannel {
  WEB
  EMAIL
  TELEGRAM
}

enum WhaleNotificationDeliveryStatus {
  PENDING
  SENT
  FAILED
  SKIPPED_COOLDOWN
}

model WhaleNotificationRule {
  id              String                    @id @default(cuid())
  userId          String                    @map("user_id")
  type            WhaleNotificationRuleType
  whaleAddress    String?                   @map("whale_address")
  symbol          String?
  thresholdUsd    Decimal                   @map("threshold_usd") @db.Decimal(30, 10)
  note            String?                   @db.Text
  channelWeb      Boolean                   @default(true) @map("channel_web")
  channelEmail    Boolean                   @default(false) @map("channel_email")
  channelTelegram Boolean                   @default(false) @map("channel_telegram")
  isActive        Boolean                   @default(true) @map("is_active")
  createdAt       DateTime                  @default(now()) @map("created_at")
  updatedAt       DateTime                  @default(now()) @updatedAt @map("updated_at")

  user            User                                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  addressTargets  WhaleNotificationRuleAddress[]
  symbolOverrides WhaleNotificationRuleSymbolOverride[]
  deliveries      WhaleNotificationDelivery[]

  @@index([userId, createdAt], map: "idx_whale_notify_rules_user_created")
  @@index([userId, isActive], map: "idx_whale_notify_rules_user_active")
  @@map("whale_notification_rules")
}

model WhaleNotificationRuleAddress {
  id           String   @id @default(cuid())
  ruleId       String   @map("rule_id")
  whaleAddress String   @map("whale_address")
  createdAt    DateTime @default(now()) @map("created_at")

  rule WhaleNotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, whaleAddress], map: "uniq_whale_notify_rule_address")
  @@index([whaleAddress], map: "idx_whale_notify_rule_address")
  @@map("whale_notification_rule_addresses")
}

model WhaleNotificationRuleSymbolOverride {
  id               String   @id @default(cuid())
  ruleId           String   @map("rule_id")
  whaleAddress     String?  @map("whale_address")
  symbol           String
  minTradeValueUsd Decimal  @map("min_trade_value_usd") @db.Decimal(30, 10)
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at")

  rule WhaleNotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@unique([ruleId, whaleAddress, symbol], map: "uniq_whale_notify_rule_symbol_override")
  @@index([symbol], map: "idx_whale_notify_rule_override_symbol")
  @@map("whale_notification_rule_symbol_overrides")
}

model WhaleNotificationDelivery {
  id            String                          @id @default(cuid())
  userId        String                          @map("user_id")
  ruleId        String                          @map("rule_id")
  dedupKey      String                          @map("dedup_key")
  channel       WhaleNotificationChannel
  status        WhaleNotificationDeliveryStatus
  whaleAddress  String                          @map("whale_address")
  symbol        String
  side          String
  tradeValueUsd Decimal                         @map("trade_value_usd") @db.Decimal(30, 10)
  tradeTime     DateTime                        @map("trade_time")
  title         String?
  content       String?                         @db.Text
  isRead        Boolean                         @default(false) @map("is_read")
  errorMessage  String?                         @map("error_message") @db.Text
  createdAt     DateTime                        @default(now()) @map("created_at")
  updatedAt     DateTime                        @default(now()) @updatedAt @map("updated_at")

  user User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  rule WhaleNotificationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([dedupKey, channel, createdAt], map: "idx_whale_notify_delivery_dedup")
  @@index([userId, createdAt], map: "idx_whale_notify_delivery_user_created")
  @@index([status, createdAt], map: "idx_whale_notify_delivery_status_created")
  @@map("whale_notification_deliveries")
}

model WhaleNotificationCooldownGuard {
  id        String   @id @default(cuid())
  dedupKey  String   @map("dedup_key")
  channel   String
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([dedupKey, channel], map: "uniq_whale_notify_cooldown_guard")
  @@index([expiresAt], map: "idx_whale_notify_cooldown_guard_expires")
  @@map("whale_notification_cooldown_guards")
}
