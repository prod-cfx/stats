/// 市场数据时间粒度枚举
enum MarketTimeframe {
  /// 说明：Prisma Client 侧使用 m1/m5/... 作为枚举键名，数据库存储 "1m"/"5m"/...
  /// 这样可以复用后端现有的 mapTimeframe/reverseMapTimeframe 映射工具，确保 API/SDK 看到的始终是 "1m" 等值
  m1  @map("1m")
  m3  @map("3m")
  m5  @map("5m")
  m15 @map("15m")
  m30 @map("30m")
  h1  @map("1h")
  h4  @map("4h")
  h6  @map("6h")
  h8  @map("8h")
  h12 @map("12h")
  d1  @map("1d")
  w1  @map("1w")
}

/// 市场数据相关模型：多空比（long/short ratio）
///
/// 说明：
/// - tradingPairId 对应业务层的 TradingPairConfig.id（例如 'BTCUSDT.BINANCE.PERP'）
/// - 不直接建外键，保持与业务配置表解耦
model LongShortRatio {
  id Int @id @default(autoincrement())

  /// 交易对配置 ID（来自 @ai/shared 中的 TradingPairConfig.id）
  tradingPairId String @map("trading_pair_id")

  /// 时间粒度，使用枚举类型确保数据一致性
  interval MarketTimeframe

  /// 该时间粒度对应的时间点（通常为区间起始时间）
  timestamp DateTime

  /// 多空比（多/空）
  longShortRatio Decimal @map("long_short_ratio") @db.Decimal(18, 8)

  /// 多头账户占比
  longAccountRatio Decimal? @map("long_account_ratio") @db.Decimal(18, 8)

  /// 空头账户占比
  shortAccountRatio Decimal? @map("short_account_ratio") @db.Decimal(18, 8)

  /// 多头仓位名义价值 / 数量
  longVolume Decimal? @map("long_volume") @db.Decimal(30, 10)

  /// 空头仓位名义价值 / 数量
  shortVolume Decimal? @map("short_volume") @db.Decimal(30, 10)

  /// 账户多空比
  longShortAccountRatio Decimal? @map("long_short_account_ratio") @db.Decimal(18, 8)

  /// 数据来源，例如：'COINGLASS'
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([tradingPairId, interval, timestamp], map: "uniq_long_short_ratio_pair_interval_time")
  @@index([tradingPairId, timestamp], map: "idx_long_short_ratio_pair_time")
  @@map("long_short_ratios")
}

/// 期货价格历史 OHLC 模型（Coinglass Futures Price History）
///
/// 参考文档：
/// https://docs.coinglass.com/v4.0-zh/reference/price-ohlc-history
///
/// 设计说明：
/// - 每条记录表示某个币种在特定时间粒度 & 交易所 & 合约类型上的 K 线数据
/// - interval 复用 MarketTimeframe，方便与其他市场数据对齐
model FuturesPriceHistory {
  id Int @id @default(autoincrement())

  /// 币种基础资产或交易对符号，例如 BTC / BTCUSDT
  symbol String

  /// 交易所代码，例如 BINANCE / OKX
  exchangeCode String @map("exchange_code")

  /// 合约类型（如 PERPETUAL、CURRENT_QUARTER 等），可选
  contractType String? @map("contract_type")

  /// 时间粒度（例如 4h / 1h），使用枚举统一管理
  interval MarketTimeframe

  /// 该时间粒度对应的时间点（通常为区间起始时间），来自响应中的 time 字段
  timestamp DateTime

  /// 开盘价
  open Decimal @db.Decimal(30, 10)

  /// 最高价
  high Decimal @db.Decimal(30, 10)

  /// 最低价
  low Decimal @db.Decimal(30, 10)

  /// 收盘价
  close Decimal @db.Decimal(30, 10)

  /// 成交量（USD 名义价值），对应 volume_usd 字段
  volumeUsd Decimal? @map("volume_usd") @db.Decimal(30, 10)

  /// 数据来源，例如：'COINGLASS'
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([symbol, exchangeCode, contractType, interval, timestamp], map: "uniq_futures_price_symbol_exchange_contract_interval_time")
  @@index([symbol, exchangeCode, interval, timestamp], map: "idx_futures_price_symbol_exchange_interval_time")
  @@map("futures_price_history")
}

/// 持仓量数据模型 - 记录加密货币期货的未平仓合约数据
model OpenInterest {
  id Int @id @default(autoincrement())

  // 基础信息
  exchange String /// 交易所名称，"All" 表示所有交易所汇总
  symbol   String /// 币种符号，如 "BTC", "ETH"

  // 未平仓合约数据
  /// 未平仓合约价值(USD)，表示所有未平仓合约的总价值
  openInterestUsd      Decimal @map("open_interest_usd") @db.Decimal(20, 4)
  /// 未平仓合约数量，表示所有未平仓合约的总数量
  openInterestQuantity Decimal @map("open_interest_quantity") @db.Decimal(20, 8)

  // 按保证金类型分类的未平仓合约数据
  /// 稳定币本位未平仓合约价值(USD)，合约采用稳定币作为保证金
  openInterestByStableCoinMargin         Decimal? @map("open_interest_by_stable_coin_margin") @db.Decimal(20, 4)
  /// 币本位未平仓合约价值(USD)，合约采用币本位作为保证金
  openInterestByCoinMargin               Decimal? @map("open_interest_by_coin_margin") @db.Decimal(20, 4)
  /// 币本位未平仓合约数量
  openInterestQuantityByCoinMargin       Decimal? @map("open_interest_quantity_by_coin_margin") @db.Decimal(20, 8)
  /// 稳定币本位未平仓合约数量
  openInterestQuantityByStableCoinMargin Decimal? @map("open_interest_quantity_by_stable_coin_margin") @db.Decimal(20, 8)

  // 变化百分比数据 - 使用 Decimal 存储以保持精度
  /// 5分钟内未平仓合约变化百分比
  openInterestChangePercent5m  Decimal? @map("open_interest_change_percent_5m") @db.Decimal(10, 4)
  /// 15分钟内未平仓合约变化百分比
  openInterestChangePercent15m Decimal? @map("open_interest_change_percent_15m") @db.Decimal(10, 4)
  /// 30分钟内未平仓合约变化百分比
  openInterestChangePercent30m Decimal? @map("open_interest_change_percent_30m") @db.Decimal(10, 4)
  /// 1小时内未平仓合约变化百分比
  openInterestChangePercent1h  Decimal? @map("open_interest_change_percent_1h") @db.Decimal(10, 4)
  /// 4小时内未平仓合约变化百分比
  openInterestChangePercent4h  Decimal? @map("open_interest_change_percent_4h") @db.Decimal(10, 4)
  /// 24小时内未平仓合约变化百分比
  openInterestChangePercent24h Decimal? @map("open_interest_change_percent_24h") @db.Decimal(10, 4)

  // 元数据
  /// 数据时间戳，表示该数据采集的时间
  dataTimestamp DateTime @map("data_timestamp")
  /// 数据创建时间
  createdAt     DateTime @default(now()) @map("created_at")
  /// 数据更新时间
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  // 索引
  @@unique([exchange, symbol, dataTimestamp], name: "open_interest_exchange_symbol_data_timestamp_key")
  @@index([symbol, dataTimestamp], name: "idx_oi_symbol_timestamp")
  @@index([exchange, dataTimestamp], name: "idx_oi_exchange_timestamp")
  @@index([dataTimestamp], name: "idx_oi_timestamp")
  @@map("open_interest")
}

/// 合约币种爆仓历史（Aggregated Liquidation History）
///
/// 参考文档：
/// https://docs.coinglass.com/v4.0-zh/reference/aggregated-liquidation-history
///
/// 设计说明：
/// - 每条记录表示某个币种在特定时间粒度 & 时间点上的多空爆仓金额（USD）
/// - interval 复用 MarketTimeframe，方便与其他市场数据对齐
model AggregatedLiquidationHistory {
  id Int @id @default(autoincrement())

  /// 币种基础资产，例如 BTC / ETH
  symbol String

  /// 交易所 (如 BINANCE / OKX)，'AGGREGATED' 表示全市场聚合
  exchangeCode String @default("AGGREGATED") @map("exchange_code")

  /// 时间粒度字符串（例如 1m / 4h / 12h / 1w）
  /// 使用字符串而不是枚举，避免受全局 MarketTimeframe 限制
  interval String

  /// 该时间粒度对应的时间点（通常为区间起始时间），来自响应中的 time 字段
  timestamp DateTime

  /// 多头爆仓金额（USD）
  longLiquidationUsd Decimal @map("aggregated_long_liquidation_usd") @db.Decimal(30, 10)

  /// 空头爆仓金额（USD）
  shortLiquidationUsd Decimal @map("aggregated_short_liquidation_usd") @db.Decimal(30, 10)

  /// 数据来源，例如：'COINGLASS'
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([symbol, exchangeCode, interval, timestamp], map: "uniq_agg_liq_symbol_exchange_interval_time")
  @@index([symbol, exchangeCode, timestamp], map: "idx_agg_liq_symbol_exchange_time")
  @@map("aggregated_liquidation_history")
}

/// Hyperliquid 鲸鱼持仓预警（Whale Alert）
///
/// 参考文档：
/// https://docs.coinglass.com/v4.0-zh/reference/hyperliquid-whale-alert
///
/// 设计说明：
/// - 记录 Hyperliquid 平台上的大额持仓开仓/平仓活动
/// - positionSize 为正数表示多头，负数表示空头
/// - positionAction: 1 = 开仓, 2 = 平仓
model HyperliquidWhaleAlert {
  id Int @id @default(autoincrement())

  /// 用户地址（hash address）
  userAddress String @map("user_address")

  /// 币种符号，如 BTC / ETH
  symbol String

  /// 持仓大小（正数=多头，负数=空头）
  positionSize Decimal @map("position_size") @db.Decimal(30, 10)

  /// 入场价格
  entryPrice Decimal @map("entry_price") @db.Decimal(30, 10)

  /// 清算价格
  liquidationPrice Decimal @map("liquidation_price") @db.Decimal(30, 10)

  /// 持仓价值（USD）
  positionValueUsd Decimal @map("position_value_usd") @db.Decimal(30, 10)

  /// 持仓操作类型：1 = 开仓, 2 = 平仓
  positionAction Int @map("position_action")

  /// 持仓创建/变动时间
  createTime DateTime @map("create_time")

  /// 数据来源，默认 'COINGLASS'
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  /// 联合唯一约束：同一用户、币种、时间点的持仓变动应该是唯一的
  @@unique([userAddress, symbol, createTime, positionAction], map: "uniq_whale_alert_user_symbol_time_action")
  @@index([symbol, createTime], map: "idx_whale_alert_symbol_time")
  @@index([userAddress, createTime], map: "idx_whale_alert_user_time")
  @@index([createTime], map: "idx_whale_alert_time")
  @@index([positionValueUsd], map: "idx_whale_alert_value")
  @@map("hyperliquid_whale_alerts")
}

/// 加密股票报价数据模型 - 记录加密货币相关股票的实时报价信息
///
/// 设计说明：
/// - 存储加密货币相关股票（如 MSTR, COIN, MARA 等）的报价数据
/// - 支持多个数据源（如 BBX 等）
/// - 记录完整的报价信息包括价格、成交量、涨跌幅等
model CryptoStockQuote {
  id Int @id @default(autoincrement())

  /// 股票代码，如 MSTR, COIN, MARA
  symbol String

  /// 股票名称
  name String?

  /// 交易所代码，如 NASDAQ, NYSE
  exchange String?

  /// 当前价格
  price Decimal @db.Decimal(20, 8)

  /// 开盘价
  openPrice Decimal? @map("open_price") @db.Decimal(20, 8)

  /// 最高价
  highPrice Decimal? @map("high_price") @db.Decimal(20, 8)

  /// 最低价
  lowPrice Decimal? @map("low_price") @db.Decimal(20, 8)

  /// 收盘价（前一交易日）
  closePrice Decimal? @map("close_price") @db.Decimal(20, 8)

  /// 成交量
  volume Decimal? @db.Decimal(30, 10)

  /// 成交额
  turnover Decimal? @db.Decimal(30, 10)

  /// 涨跌额
  priceChange Decimal? @map("price_change") @db.Decimal(20, 8)

  /// 涨跌幅（百分比）
  priceChangePercent Decimal? @map("price_change_percent") @db.Decimal(10, 4)

  /// 市值
  marketCap Decimal? @map("market_cap") @db.Decimal(30, 2)

  /// 市盈率
  peRatio Decimal? @map("pe_ratio") @db.Decimal(10, 4)

  /// 52周最高价
  high52Week Decimal? @map("high_52_week") @db.Decimal(20, 8)

  /// 52周最低价
  low52Week Decimal? @map("low_52_week") @db.Decimal(20, 8)

  /// 净资产值比率 (mNAV)，币股特有指标
  mNav Decimal? @map("m_nav") @db.Decimal(30, 10)

  /// 持仓金额 (USD)
  holdingValue Decimal? @map("holding_value") @db.Decimal(30, 10)

  /// 持仓数量
  holdingQuantity Decimal? @map("holding_quantity") @db.Decimal(30, 10)

  /// 公司类型标签，如 "Crypto Strategic Reserve", "Crypto Mining"
  companyType String? @map("company_type")

  /// 数据源，例如：'BBX'
  source String @default("BBX")

  /// 报价时间戳
  quoteTimestamp DateTime @map("quote_timestamp")

  /// 额外的 JSON 数据，用于存储 API 返回的其他字段
  rawData Json? @map("raw_data")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([symbol, source, quoteTimestamp], map: "uniq_crypto_stock_quote_symbol_source_time")
  @@index([symbol, quoteTimestamp], map: "idx_crypto_stock_quote_symbol_time")
  @@index([source, quoteTimestamp], map: "idx_crypto_stock_quote_source_time")
  @@map("crypto_stock_quotes")
}

/// 交易记录数据模型 - 记录交易所的最近成交数据
///
/// 设计说明：
/// - 存储各交易所的实时成交记录（trades）
/// - 支持现货、永续合约、期货等不同合约类型
/// - 用于展示最新成交和大额成交
model MarketTrade {
  id Int @id @default(autoincrement())

  /// 交易所代码，如 OKX, BINANCE
  exchange String

  /// 合约类型：SPOT, PERPETUAL, FUTURE
  instrumentType String @map("instrument_type")

  /// 交易对符号，如 BTC-USDT, ETH-USDT-SWAP
  symbol String

  /// 基础资产，如 BTC, ETH
  baseAsset String @map("base_asset")

  /// 计价资产，如 USDT, USD
  quoteAsset String @map("quote_asset")

  /// 交易ID（交易所提供的唯一标识）
  tradeId String @map("trade_id")

  /// 交易价格
  price Decimal @db.Decimal(30, 10)

  /// 交易数量
  size Decimal @db.Decimal(30, 10)

  /// 交易方向：buy 或 sell（主动买入或主动卖出）
  side String

  /// 交易时间戳（毫秒）
  tradeTimestamp BigInt @map("trade_timestamp")

  /// 数据创建时间
  createdAt DateTime @default(now()) @map("created_at")

  /// 数据更新时间
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  // 索引
  @@unique([exchange, instrumentType, symbol, tradeId], name: "market_trade_exchange_instrument_symbol_tradeid_key")
  @@index([exchange, instrumentType, symbol, tradeTimestamp], name: "idx_trade_exchange_instrument_symbol_time")
  @@index([tradeTimestamp], name: "idx_trade_timestamp")
  @@index([baseAsset, quoteAsset, tradeTimestamp], name: "idx_trade_assets_time")
  @@map("market_trades")
}
