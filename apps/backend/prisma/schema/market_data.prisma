/// 期货交易对市场数据快照（Coinglass Pairs-Markets）
///
/// 参考文档：
/// https://docs.coinglass.com/v4.0-zh/reference/pairs-markets
///
/// 设计说明：
/// - 快照模式（snapshot-only），使用 upsert 更新现有记录
/// - 包含资金费率字段（funding_rate / next_funding_time），避免分表复杂度
/// - 唯一键：(symbol, exchangeName, instrumentId)
model FuturesPairsMarket {
  id Int @id @default(autoincrement())

  /// 合约 ID（如 BTCUSDT）
  instrumentId String @map("instrument_id")

  /// 交易所名称（如 Binance / OKX）
  exchangeName String @map("exchange_name")

  /// 交易对符号（如 BTC/USDT）
  symbol String

  /// 当前价格
  currentPrice Decimal @map("current_price") @db.Decimal(30, 10)

  /// 指数价格
  indexPrice Decimal? @map("index_price") @db.Decimal(30, 10)

  /// 24小时价格变化百分比
  priceChangePercent24h Decimal? @map("price_change_percent_24h") @db.Decimal(10, 4)

  /// 24小时成交量（USD）
  volumeUsd Decimal @map("volume_usd") @db.Decimal(30, 10)

  /// 24小时成交量变化百分比
  volumeUsdChangePercent24h Decimal? @map("volume_usd_change_percent_24h") @db.Decimal(10, 4)

  /// 多头成交量（USD）
  longVolumeUsd Decimal? @map("long_volume_usd") @db.Decimal(30, 10)

  /// 空头成交量（USD）
  shortVolumeUsd Decimal? @map("short_volume_usd") @db.Decimal(30, 10)

  /// 多头成交量（数量）
  /// 注：使用 Decimal(40,10) 支持低价币（如 PEPE $0.0000001）的大数量值
  /// 低价币数量可达数十万亿（16位整数），例如：1M USD ÷ $0.0000001 = 10^16
  longVolumeQuantity Decimal? @map("long_volume_quantity") @db.Decimal(40, 10)

  /// 空头成交量（数量）
  /// 注：使用 Decimal(40,10) 支持低价币（如 PEPE $0.0000001）的大数量值
  /// 低价币数量可达数十万亿（16位整数），例如：1M USD ÷ $0.0000001 = 10^16
  shortVolumeQuantity Decimal? @map("short_volume_quantity") @db.Decimal(40, 10)

  /// 持仓量（数量）
  /// 注：使用 Decimal(40,10) 支持低价币（如 PEPE $0.0000001）的大数量值
  /// 低价币数量可达数十万亿（16位整数），例如：1M USD ÷ $0.0000001 = 10^16
  openInterestQuantity Decimal? @map("open_interest_quantity") @db.Decimal(40, 10)

  /// 持仓量（USD）
  openInterestUsd Decimal? @map("open_interest_usd") @db.Decimal(30, 10)

  /// 24小时持仓量变化百分比
  openInterestChangePercent24h Decimal? @map("open_interest_change_percent_24h") @db.Decimal(10, 4)

  /// 24小时多头清算金额（USD）
  longLiquidationUsd24h Decimal? @map("long_liquidation_usd_24h") @db.Decimal(30, 10)

  /// 24小时空头清算金额（USD）
  shortLiquidationUsd24h Decimal? @map("short_liquidation_usd_24h") @db.Decimal(30, 10)

  /// 资金费率
  fundingRate Decimal? @map("funding_rate") @db.Decimal(18, 8)

  /// 下次资金费率时间（毫秒时间戳）
  nextFundingTime BigInt? @map("next_funding_time")

  /// 持仓量/成交量比率
  openInterestVolumeRatio Decimal? @map("open_interest_volume_ratio") @db.Decimal(10, 4)

  /// 24小时持仓量/成交量比率变化百分比
  oiVolRatioChangePercent24h Decimal? @map("oi_vol_ratio_change_percent_24h") @db.Decimal(10, 4)

  /// 数据来源
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([symbol, exchangeName, instrumentId], map: "uniq_futures_pairs_market_symbol_exchange_instrument")
  @@index([symbol, exchangeName], map: "idx_futures_pairs_market_symbol_exchange")
  @@index([exchangeName], map: "idx_futures_pairs_market_exchange")
  @@map("futures_pairs_markets")
}

/// Hyperliquid 用户成交历史记录
///
/// 设计说明：
/// - 存储用户在 Hyperliquid 平台的历史成交记录
/// - 用于分析交易行为、计算 PnL 趋势等
/// - 通过增量同步任务定期从 Hyperliquid API 拉取数据
model HyperliquidUserFill {
  id Int @id @default(autoincrement())

  /// 用户地址
  userAddress String @map("user_address")

  /// 币种符号
  coin String

  /// 成交价格
  price Decimal @db.Decimal(30, 10)

  /// 成交数量（正=多，负=空）
  size Decimal @db.Decimal(30, 10)

  /// 方向（A = 主动买入, B = 主动卖出）
  side String

  /// 成交时间
  time DateTime

  /// 成交前持仓数量
  startPosition Decimal @map("start_position") @db.Decimal(30, 10)

  /// 仓位变化方向
  direction String @map("dir")

  /// 已实现盈亏
  closedPnl Decimal @map("closed_pnl") @db.Decimal(30, 10)

  /// 交易哈希
  hash String

  /// 订单 ID
  orderId BigInt @map("order_id") @db.BigInt

  /// 成交 ID
  tradeId BigInt @map("trade_id") @db.BigInt

  /// 是否为吃单
  crossed Boolean

  /// 手续费
  fee Decimal @db.Decimal(30, 10)

  /// 是否为强平
  liquidation Boolean

  /// 数据来源
  source String @default("HYPERLIQUID")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userAddress, coin, time, tradeId], map: "uniq_hyperliquid_user_fill")
  @@index([userAddress, time], map: "idx_hyperliquid_fill_user_time")
  @@index([coin, time], map: "idx_hyperliquid_fill_coin_time")
  @@map("hyperliquid_user_fills")
}

/// Hyperliquid 用户订单历史记录
///
/// 设计说明：
/// - 存储用户在 Hyperliquid 平台的历史订单记录
/// - 包含限价单、市价单、止损单等各类订单类型
/// - 用于订单历史查询和交易行为分析
model HyperliquidUserOrder {
  id Int @id @default(autoincrement())

  /// 用户地址
  userAddress String @map("user_address")

  /// 币种符号
  coin String

  /// 订单 ID
  orderId BigInt @map("order_id") @db.BigInt

  /// 客户端订单 ID（可选）
  clientOrderId String? @map("client_order_id")

  /// 方向（A = 买入, B = 卖出）
  side String

  /// 限价
  limitPrice Decimal @map("limit_price") @db.Decimal(30, 10)

  /// 订单数量
  size Decimal @db.Decimal(30, 10)

  /// 原始数量
  originalSize Decimal @map("original_size") @db.Decimal(30, 10)

  /// 订单类型（limit, market, stop, etc.）
  orderType String? @map("order_type")

  /// 触发价格（止损/止盈订单）
  triggerPrice Decimal? @map("trigger_price") @db.Decimal(30, 10)

  /// 触发条件
  triggerCondition String? @map("trigger_condition")

  /// 是否只减仓
  reduceOnly Boolean? @map("reduce_only")

  /// 订单状态（open, filled, canceled, rejected）
  status String

  /// 订单创建时间
  timestamp DateTime

  /// 数据来源
  source String @default("HYPERLIQUID")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userAddress, orderId], map: "uniq_hyperliquid_user_order")
  @@index([userAddress, timestamp], map: "idx_hyperliquid_order_user_time")
  @@index([status, timestamp], map: "idx_hyperliquid_order_status_time")
  @@map("hyperliquid_user_orders")
}

/// Hyperliquid 用户资金费率历史
///
/// 设计说明：
/// - 存储用户在 Hyperliquid 平台的资金费率支付/收取记录
/// - 用于分析持仓成本和资金费率趋势
/// - 资金费率每 8 小时结算一次
model HyperliquidUserFunding {
  id Int @id @default(autoincrement())

  /// 用户地址
  userAddress String @map("user_address")

  /// 币种符号
  coin String

  /// 资金费率金额（正=收入，负=支出）
  fundingRate Decimal @map("funding_rate") @db.Decimal(30, 10)

  /// 持仓数量
  szi Decimal @db.Decimal(30, 10)

  /// USDC 金额
  usdc Decimal @db.Decimal(30, 10)

  /// 时间戳
  time DateTime

  /// 数据来源
  source String @default("HYPERLIQUID")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userAddress, coin, time], map: "uniq_hyperliquid_user_funding")
  @@index([userAddress, time], map: "idx_hyperliquid_funding_user_time")
  @@map("hyperliquid_user_funding")
}

/// 大户持仓多空比历史（Coinglass Top Long/Short Position Ratio）
///
/// 参考文档：
/// https://docs.coinglass.com/v4.0-zh/reference/top-longshort-position-ratio
///
/// Taker 主动买卖成交量数据（Coinglass Taker Buy/Sell Volume）
///
/// 参考文档：
/// https://docs.coinglass.com/reference/taker-buysell-volume
///
/// 设计说明：
/// - 每条记录表示某个交易所在特定币种、特定时间范围内的主动买卖成交量
/// - 主动买入/卖出比例总和为 100%
/// - 用于分析市场情绪和资金流向
model TakerBuySellVolume {
  id Int @id @default(autoincrement())

  /// 交易所名称（如 Binance / OKX / Bybit）
  exchange String

  /// 币种符号（如 BTC / ETH / SOL）
  symbol String

  /// 时间范围（如 24h / 1d / 7d）
  range String

  /// 数据时间点
  timestamp DateTime

  /// 主动买入占比（百分比，如 48.07）
  buyRatio Decimal @map("buy_ratio") @db.Decimal(10, 4)

  /// 主动卖出占比（百分比，如 51.93）
  sellRatio Decimal @map("sell_ratio") @db.Decimal(10, 4)

  /// 主动买入成交量（USD）
  buyVolUsd Decimal @map("buy_vol_usd") @db.Decimal(20, 2)

  /// 主动卖出成交量（USD）
  sellVolUsd Decimal @map("sell_vol_usd") @db.Decimal(20, 2)

  /// 数据来源，例如：'COINGLASS'
  source String @default("COINGLASS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([exchange, symbol, range, timestamp], map: "uniq_taker_volume_exchange_symbol_range_time")
  @@index([exchange, symbol, timestamp], map: "idx_taker_volume_exchange_symbol_time")
  @@map("taker_buy_sell_volumes")
}


/// Hyperliquid 鲸鱼交易记录（Whale Trades）
///
/// 设计说明：
/// - 存储 WebSocket 推送的单笔交易记录（非持仓数据）
/// - 交易记录为 append-only，不做 upsert
/// - 用于实时鲸鱼交易监控和 SSE 推送
model HyperliquidWhaleTrade {
  id Int @id @default(autoincrement())

  /// 鲸鱼地址（Hyperliquid 用户地址）
  userAddress String @map("user_address")

  /// 币种符号，如 BTC / ETH
  symbol String

  /// 交易方向：Long / Short
  side String

  /// 交易数量（绝对值）
  tradeSize Decimal @map("trade_size") @db.Decimal(30, 10)

  /// 交易价格
  price Decimal @db.Decimal(30, 10)

  /// 交易价值（USD）= price * tradeSize
  tradeValueUsd Decimal @map("trade_value_usd") @db.Decimal(30, 10)

  /// 交易时间
  tradeTime DateTime @map("trade_time")

  /// 数据来源，默认 'HYPERLIQUID_WS'
  source String @default("HYPERLIQUID_WS")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  @@unique([userAddress, symbol, tradeTime, side], map: "uniq_whale_trade_user_symbol_time_side")
  @@index([symbol, tradeTime], map: "idx_whale_trade_symbol_time")
  @@index([userAddress, tradeTime], map: "idx_whale_trade_user_time")
  @@index([tradeTime], map: "idx_whale_trade_time")
  @@index([tradeValueUsd], map: "idx_whale_trade_value")
  @@map("hyperliquid_whale_trades")
}
