{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "commonjs",
    "paths": {
      "@ai/shared": ["packages/shared/src/index.ts"],
      "@ai/shared/*": ["packages/shared/src/*"],
      "@ai/api-contracts": ["packages/api-contracts/src/index.ts"],
      "@ai/api-contracts/*": ["packages/api-contracts/src/*"],
      "@net/config": ["packages/config/src/index.ts"],
      "@net/config/*": ["packages/config/src/*"],
      "@/*": ["apps/quantify/src/*"]
    },
    "tsBuildInfoFile": "dist/tsconfig.tsbuildinfo"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
