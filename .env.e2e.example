# E2E 测试环境配置
APP_ENV=e2e
NODE_ENV=test

# 数据库配置（必须包含 e2e 或 test 关键词）
DATABASE_URL=__SET_IN_env.local__

# 端口配置
PORT=3000

# 其他环境变量根据项目需要添加...
# 例如：
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_DB=1
# JWT_SECRET=test-secret-key-for-e2e
#
# 前端/管理端使用的后端基础地址（公开变量）
# NEXT_PUBLIC_API_SERVER_URL=http://localhost:3000

# Trades WebSocket ingestion (markets/trades)
# Enable trades WS ingestion (set true to enable)
TRADES_WS_ENABLED=false

# Sync interval (ms), minimum 1000
TRADES_WS_SYNC_INTERVAL_MS=10000

# OKX trades WS base URL (no path)
# e.g. wss://ws.okx.com:8443
TRADES_OKX_WS_BASE_URL=

# Max streams per WS connection (sharding)
TRADES_OKX_MAX_STREAMS_PER_CONNECTION=50

# Trades retention days (CleanupOldTradesJob)
TRADES_RETENTION_DAYS=7
